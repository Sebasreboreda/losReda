<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
</head>
<body class="site">
  <%- include('partials/header') %>

  <main class="site-main">
    <div class="content-shell">
      <h1 class="page-title">Crear cuenta</h1>
      <div class="form-panel">
        <%- include('partials/formError', { errorMessage: error }) %>
        <form action="/registro" method="post">
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <%- include('partials/formError', { errorMessage: errorNombre }) %>
            <input id="nombre" type="text" name="nombre" required value="<%= typeof nombre !== 'undefined' && nombre ? nombre : '' %>" />
          </div>
          <div class="form-group">
            <label for="correo">Correo</label>
            <%- include('partials/formError', { errorMessage: errorCorreo }) %>
            <input id="correo" type="email" name="correo" required value="<%= typeof correo !== 'undefined' && correo ? correo : '' %>" />
          </div>
          <div class="form-group">
            <label for="contrasena">Contraseña</label>
            <%- include('partials/formError', { errorMessage: errorContraseña }) %>
            <input id="contrasena" type="password" name="contrasena" required />
          </div>
          <div class="form-group">
            <label for="verificar_contrasena">Verificar contraseña</label>
            <input id="verificar_contrasena" type="password" name="verificar_contrasena" required />
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Crear cuenta</button>
          </div>
        </form>
        <a href="/" class="back-link">← Volver al inicio</a>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
