<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
</head>
<body class="site">
  <%- include('partials/header') %>

  <main class="site-main">
    <div class="content-shell">
      <%- include('partials/crearPersonajePageHeader', { activeStep: 4 }) %>

      <div class="form-panel form-panel--wide form-panel--plain crear-personaje-panel--wide">
        <%- include('partials/crearPersonajeImagePickerCard', { imagenesDisponibles }) %>

        <section class="crear-paso4-grid" aria-label="Resumen final del personaje">
          <article class="crear-personaje-card crear-paso4-card">
            <h2 class="crear-paso4-card__title">Clase, subclase y linaje</h2>
            <div id="cp4-resumen-identidad" class="crear-paso4-card__body"></div>
          </article>

          <article class="crear-personaje-card crear-paso4-card">
            <h2 class="crear-paso4-card__title">Trasfondo</h2>
            <div id="cp4-resumen-detalles" class="crear-paso4-card__body"></div>
          </article>

          <article class="crear-personaje-card crear-paso4-card">
            <h2 class="crear-paso4-card__title">Atributos y competencias</h2>
            <div id="cp4-resumen-atributos" class="crear-paso4-card__body"></div>
            <div id="cp4-resumen-competencias" class="crear-paso4-card__body crear-paso4-card__body--spaced"></div>
            <div class="crear-paso4-card__body crear-paso4-card__body--spaced">
              <p class="crear-paso4-line"><strong>Tiradas de salvación</strong></p>
              <div id="cp4-resumen-salvaciones">—</div>
            </div>
          </article>

          <article class="crear-personaje-card crear-paso4-card">
            <h2 class="crear-paso4-card__title">Habilidades</h2>
            <div id="cp4-resumen-habilidades" class="crear-paso4-card__body"></div>
          </article>
        </section>

        <div class="form-actions">
          <a href="/personajes/crear/3" class="btn btn-secondary">Anterior</a>
          <a href="/personajes/crear/finalizar" class="btn btn-primary">Finalizar</a>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/avatarPickerToggleScript') %>
  <script id="cp4-clases-data" type="application/json"><%- JSON.stringify(clases || []).replace(/</g, '\\u003c') %></script>
  <script id="cp4-razas-data" type="application/json"><%- JSON.stringify(razas || []).replace(/</g, '\\u003c') %></script>
  <script id="cp4-subrazas-data" type="application/json"><%- JSON.stringify(subrazas || []).replace(/</g, '\\u003c') %></script>
  <script id="cp4-subclases-data" type="application/json"><%- JSON.stringify(subclases || []).replace(/</g, '\\u003c') %></script>
  <script id="cp4-trasfondos-data" type="application/json"><%- JSON.stringify(trasfondos || []).replace(/</g, '\\u003c') %></script>
  <script id="cp4-atributos-data" type="application/json"><%- JSON.stringify(atributos || []).replace(/</g, '\\u003c') %></script>
  <script id="cp4-competencias-catalogo-data" type="application/json"><%- JSON.stringify(competenciasCatalogo || []).replace(/</g, '\\u003c') %></script>
  <script id="cp4-textos-directos-data" type="application/json"><%- JSON.stringify(textosDirectos || {}).replace(/</g, '\\u003c') %></script>
  <script id="cp4-rules-data" type="application/json"><%- JSON.stringify(reglasCreacion || {}).replace(/</g, '\\u003c') %></script>
  <script src="/js/crearPersonajeRules.js"></script>
  <script>
    (function () {
      const storage = window.sessionStorage;
      const STORAGE_SELECTION_KEY = 'crearPersonaje.seleccionPaso1';
      const STORAGE_ATTRS_KEY = 'crearPersonaje.atributosPaso3';
      const STORAGE_ATTRS_STANDARD_KEY = 'crearPersonaje.atributosPaso3.standard';
      const STORAGE_ATTRS_PUNTOS_KEY = 'crearPersonaje.atributosPaso3.puntos';
      const STORAGE_ATTRS_TOTAL_STANDARD_KEY = 'crearPersonaje.atributosPaso3.total.standard';
      const STORAGE_ATTRS_TOTAL_PUNTOS_KEY = 'crearPersonaje.atributosPaso3.total.puntos';
      const STORAGE_ATTR_METHOD_KEY = 'crearPersonaje.metodoAtributosPaso3';
      const STORAGE_BG_KEY = 'crearPersonaje.trasfondoPaso3';
      const STORAGE_TEXTS_KEY = 'crearPersonaje.textosPaso3';
      const STORAGE_KNOWN_LANG_KEY = 'crearPersonaje.idiomasConocidosPaso2';
      const STORAGE_BG_LANG_KEY = 'crearPersonaje.idiomasTrasfondoPaso3';

      function parseJsonScript(id) {
        const el = document.getElementById(id);
        if (!el) return [];
        try {
          return JSON.parse(el.textContent || '[]');
        } catch {
          return [];
        }
      }

      function leerStorageJson(key, fallback) {
        try {
          const raw = storage.getItem(key);
          return raw ? JSON.parse(raw) : fallback;
        } catch {
          return fallback;
        }
      }

      function esc(txt = '') {
        return String(txt || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function tituloDesdeSlug(slug = '') {
        return String(slug || '')
          .replace(/[-_]+/g, ' ')
          .replace(/\b\w/g, (m) => m.toUpperCase())
          .trim();
      }

      function parsearJsonFlexible(valor, fallback) {
        if (valor == null) return fallback;
        if (typeof valor === 'string') {
          const s = valor.trim();
          if (!s) return fallback;
          if ((s.startsWith('[') && s.endsWith(']')) || (s.startsWith('{') && s.endsWith('}'))) {
            try {
              return JSON.parse(s);
            } catch {
              return fallback;
            }
          }
          return fallback;
        }
        return valor;
      }
      function aArraySeguro(valor) {
        const parsed = parsearJsonFlexible(valor, valor);
        if (Array.isArray(parsed)) return parsed;
        if (parsed && typeof parsed === 'object') return [parsed];
        return [];
      }

      function normalizarRef(item) {
        if (!item) return '';
        if (typeof item === 'string') return item.trim();
        return String(item?.name || item?.nombre || item?.index || item?.slug || '').trim();
      }

      function traducirNombreProficiencia(name = '') {
        const keyRaw = String(name || '').trim();
        if (!keyRaw) return '';
        const sinPrefijo = keyRaw.replace(/^(skill|saving throw|saving throws|tool|tools|instrument|instruments|language|languages|weapon|weapons|armor|armour)\s*:\s*/i, '').trim();
        const keyLower = keyRaw.toLowerCase();
        const sinPrefijoLower = sinPrefijo.toLowerCase();
        const keySlug = keyLower.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
        const sinPrefijoSlug = sinPrefijoLower.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
        const fromCatalogo =
          competenciaBySlug.get(keySlug) ||
          competenciaBySlug.get(sinPrefijoSlug) ||
          competenciaByNombre.get(keyLower) ||
          competenciaByNombre.get(sinPrefijoLower);
        if (fromCatalogo?.nombre) return String(fromCatalogo.nombre).trim();
        const traducido =
          (textosDirectos && (
            textosDirectos[keyRaw] ||
            textosDirectos[sinPrefijo] ||
            textosDirectos[keyLower] ||
            textosDirectos[sinPrefijoLower] ||
            textosDirectos[keySlug] ||
            textosDirectos[sinPrefijoSlug]
          )) ||
          '';
        return String(traducido || sinPrefijo || keyRaw).trim();
      }

      function categorizarCompetencia(valor = '') {
        const t = String(valor || '').toLowerCase();
        if (!t) return 'otros';
        if (t.includes('saving throw') || t.includes('saving-throw') || t.includes('salvacion') || t.includes('salvación')) return 'salvacion';
        if (t.includes('skill') || t.includes('acrobacias') || t.includes('arcana') || t.includes('persuasion') || t.includes('persuasión')) return 'habilidad';
        if (t.includes('armor') || t.includes('armour') || t.includes('armadura') || t.includes('shield') || t.includes('escudo')) return 'armadura';
        if (t.includes('weapon') || t.includes('arma')) return 'arma';
        if (t.includes('language') || t.includes('idioma')) return 'idioma';
        if (t.includes('tool') || t.includes('kit') || t.includes('instrument') || t.includes('herramient')) return 'herramienta';
        return 'otros';
      }

      const clases = parseJsonScript('cp4-clases-data');
      const razas = parseJsonScript('cp4-razas-data');
      const subrazas = parseJsonScript('cp4-subrazas-data');
      const subclases = parseJsonScript('cp4-subclases-data');
      const trasfondos = parseJsonScript('cp4-trasfondos-data');
      const atributosDef = parseJsonScript('cp4-atributos-data');
      const competenciasCatalogo = parseJsonScript('cp4-competencias-catalogo-data');
      const textosDirectos = parseJsonScript('cp4-textos-directos-data');
      const rulesData = parseJsonScript('cp4-rules-data');
      const attrRules = rulesData && typeof rulesData === 'object' && rulesData.atributos && typeof rulesData.atributos === 'object'
        ? rulesData.atributos
        : {};
      const ATRIBUTOS_VALIDOS = Array.isArray(attrRules.atributosValidos) && attrRules.atributosValidos.length
        ? attrRules.atributosValidos.map((a) => String(a || '').trim()).filter(Boolean)
        : ['fuerza', 'destreza', 'constitucion', 'inteligencia', 'sabiduria', 'carisma'];
      const rulesHelper = window.CrearPersonajeRules || {};

      const claseBySlug = new Map(clases.map((c) => [String(c?.slug || '').trim(), c]));
      const claseBySlugLower = new Map(clases.map((c) => [String(c?.slug || '').trim().toLowerCase(), c]));
      const razaBySlug = new Map(razas.map((r) => [String(r?.slug || '').trim(), r]));
      const subrazaBySlug = new Map(subrazas.map((s) => [String(s?.slug || '').trim(), s]));
      const subclaseBySlug = new Map(subclases.map((s) => [String(s?.slug || '').trim(), s]));
      const trasfondoBySlug = new Map(trasfondos.map((t) => [String(t?.slug || '').trim(), t]));
      const competenciaBySlug = new Map(
        (Array.isArray(competenciasCatalogo) ? competenciasCatalogo : [])
          .map((c) => [String(c?.slug || '').trim().toLowerCase(), c])
      );
      const competenciaByNombre = new Map(
        (Array.isArray(competenciasCatalogo) ? competenciasCatalogo : [])
          .map((c) => [String(c?.nombre || '').trim().toLowerCase(), c])
      );
      const competenciaSkillByNombreNorm = new Map(
        (Array.isArray(competenciasCatalogo) ? competenciasCatalogo : [])
          .filter((c) => ['habilidad', 'skill', 'skills', 'habilidades'].includes(String(c?.tipo || '').trim().toLowerCase()))
          .map((c) => [
            String(c?.nombre || '')
              .normalize('NFD')
              .replace(/[\u0300-\u036f]/g, '')
              .toLowerCase()
              .trim(),
            c
          ])
      );

      const seleccion = leerStorageJson(STORAGE_SELECTION_KEY, {});
      const resumenCompetenciasPaso2 = seleccion?.resumen_competencias_paso2 && typeof seleccion.resumen_competencias_paso2 === 'object'
        ? seleccion.resumen_competencias_paso2
        : {};
      const metodoAtributos = String(storage.getItem(STORAGE_ATTR_METHOD_KEY) || 'standard').trim().toLowerCase();
      const attrsKey = metodoAtributos === 'puntos' ? STORAGE_ATTRS_PUNTOS_KEY : STORAGE_ATTRS_STANDARD_KEY;
      const attrsTotalKey = metodoAtributos === 'puntos' ? STORAGE_ATTRS_TOTAL_PUNTOS_KEY : STORAGE_ATTRS_TOTAL_STANDARD_KEY;
      const attrs = leerStorageJson(attrsTotalKey, leerStorageJson(attrsKey, leerStorageJson(STORAGE_ATTRS_KEY, {})));
      const textos = leerStorageJson(STORAGE_TEXTS_KEY, {});
      const idiomasConocidos = leerStorageJson(STORAGE_KNOWN_LANG_KEY, []);
      const idiomasTrasfondo = leerStorageJson(STORAGE_BG_LANG_KEY, []);
      const trasfondoSlug = String(storage.getItem(STORAGE_BG_KEY) || '').trim();

      const identidadEl = document.getElementById('cp4-resumen-identidad');
      const atributosEl = document.getElementById('cp4-resumen-atributos');
      const detallesEl = document.getElementById('cp4-resumen-detalles');
      const competenciasEl = document.getElementById('cp4-resumen-competencias');
      const habilidadesEl = document.getElementById('cp4-resumen-habilidades');
      const salvacionesEl = document.getElementById('cp4-resumen-salvaciones');
      if (!identidadEl || !atributosEl || !detallesEl || !competenciasEl || !habilidadesEl || !salvacionesEl) return;

      const claseSlugSeleccion = String(seleccion?.clase || '').trim();
      const razaSlug = String(seleccion?.raza || '').trim();
      const subrazaSlug = String(seleccion?.subraza || '').trim();
      const filasClase = Array.isArray(seleccion?.multiclases) ? seleccion.multiclases : [];
      const filaPrincipal = filasClase.find((f) => String(f?.slug || '') === claseSlugSeleccion) || filasClase[0] || null;
      const claseSlug = claseSlugSeleccion || String(filaPrincipal?.slug || '').trim();
      const subclaseSlug = String(filaPrincipal?.subclase || '').trim();
      const nivelTotal = filasClase.length
        ? filasClase.reduce((acc, f) => acc + (Number(f?.nivel) || 0), 0)
        : (Number(seleccion?.nivel) || 1);

      const clase = claseBySlug.get(claseSlug) || claseBySlugLower.get(String(claseSlug || '').toLowerCase());
      const raza = razaBySlug.get(razaSlug);
      const subraza = subrazaBySlug.get(subrazaSlug);
      const subclase = subclaseBySlug.get(subclaseSlug);
      const trasfondo = trasfondoBySlug.get(trasfondoSlug);

      const nombreClase = String(clase?.nombre || tituloDesdeSlug(claseSlug) || '—').trim();
      const nombreSubclase = String(subclase?.nombre || tituloDesdeSlug(subclaseSlug) || '').trim();
      const nombreRaza = String(raza?.nombre || tituloDesdeSlug(razaSlug) || '—').trim();
      const nombreSubraza = String(subraza?.nombre || tituloDesdeSlug(subrazaSlug) || '').trim();

      identidadEl.innerHTML = `
        <p class="crear-paso4-line"><strong>Nivel:</strong> ${esc(String(nivelTotal || 1))}</p>
        <p class="crear-paso4-line"><strong>Método de atributos:</strong> ${esc(metodoAtributos === 'puntos' ? 'Método por puntos' : 'Método standard')}</p>
        <p class="crear-paso4-line"><strong>Clase:</strong> ${esc(nombreClase)}</p>
        <p class="crear-paso4-line"><strong>Subclase:</strong> ${esc(nombreSubclase || 'Sin subclase')}</p>
        <p class="crear-paso4-line"><strong>Raza:</strong> ${esc(nombreRaza)}</p>
        <p class="crear-paso4-line"><strong>Subraza:</strong> ${esc(nombreSubraza || 'Sin subraza')}</p>
      `;

      const filasAtributos = (Array.isArray(atributosDef) ? atributosDef : []).map((a) => {
        const campo = String(a?.campo || '').trim();
        if (!campo) return '';
        const nombre = String(a?.nombre || campo).trim();
        const valor = Number(attrs?.[campo]);
        const valorTxt = Number.isFinite(valor) ? String(valor) : '—';
        return `
          <div class="crear-paso4-attr-item">
            <span>${esc(nombre)}</span>
            <strong>${esc(valorTxt)}</strong>
          </div>
        `;
      }).filter(Boolean);
      atributosEl.innerHTML = filasAtributos.length
        ? `<div class="crear-paso4-attr-list">${filasAtributos.join('')}</div>`
        : '<p class="crear-paso4-muted">Sin atributos definidos.</p>';

      const bloquesTexto = [
        ['Trasfondo', trasfondo?.nombre || '—'],
        ['Alineamiento', textos?.alineamiento || '—'],
        ['Fe', textos?.fe || '—'],
        ['Estilo de vida', textos?.estiloVida || '—']
      ];
      detallesEl.innerHTML = bloquesTexto
        .map(([k, v]) => `<p class="crear-paso4-line"><strong>${esc(k)}:</strong> ${esc(v || '—')}</p>`)
        .join('');

      const competenciasPorTipo = {
        salvacion: new Set(),
        habilidad: new Set(),
        arma: new Set(),
        armadura: new Set(),
        herramienta: new Set(),
        idioma: new Set(),
        otros: new Set()
      };
      const habilidadesCompetentesPorSlug = new Set();
      const habilidadesCompetentesPorNombre = new Set();

      function agregarCompetencia(raw) {
        const base = normalizarRef(raw);
        if (!base) return;
        const baseLower = String(base).toLowerCase();
        if (
          baseLower.includes('choose ') ||
          baseLower.includes('(choose') ||
          baseLower.includes('a elegir') ||
          baseLower.includes('elige ')
        ) return;
        const nombre = traducirNombreProficiencia(base);
        if (!nombre) return;
        const slug = baseLower.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
        const fromCatalogo =
          competenciaBySlug.get(slug) ||
          competenciaByNombre.get(baseLower) ||
          competenciaByNombre.get(String(nombre || '').toLowerCase());
        const tipo = fromCatalogo?.tipo ? String(fromCatalogo.tipo).toLowerCase() : categorizarCompetencia(base);
        if (tipo === 'habilidad' || tipo === 'skill' || tipo === 'skills' || tipo === 'habilidades') {
          const slugHab = resolverSkillSlug(String(fromCatalogo?.slug || slug || nombre || ''));
          if (slugHab) habilidadesCompetentesPorSlug.add(slugHab);
          if (nombre) habilidadesCompetentesPorNombre.add(normalizarTextoComparacion(nombre));
        }
        if (!competenciasPorTipo[tipo]) competenciasPorTipo.otros.add(nombre);
        else competenciasPorTipo[tipo].add(nombre);
      }

      const competenciaClaseRaw = parsearJsonFlexible(clase?.competencia, {});
      const claseFijas = Array.isArray(competenciaClaseRaw?.proficiencies)
        ? competenciaClaseRaw.proficiencies
        : [];
      const claseSkillsFijas = Array.isArray(competenciaClaseRaw?.skills?.fixed)
        ? competenciaClaseRaw.skills.fixed
        : [];
      claseFijas.forEach(agregarCompetencia);
      claseSkillsFijas.forEach((s) => agregarCompetencia(`skill:${s}`));
      const skillsPaso2 = Array.isArray(resumenCompetenciasPaso2?.habilidades) ? resumenCompetenciasPaso2.habilidades : [];
      skillsPaso2.forEach((s) => agregarCompetencia(`skill:${s}`));

      const elegidasClase = seleccion?.competencias_clase_elegidas && typeof seleccion.competencias_clase_elegidas === 'object'
        ? Object.values(seleccion.competencias_clase_elegidas)
        : [];
      const elegidasRaza = seleccion?.competencias_raciales_elegidas && typeof seleccion.competencias_raciales_elegidas === 'object'
        ? Object.values(seleccion.competencias_raciales_elegidas)
        : [];
      [...elegidasClase, ...elegidasRaza].forEach((v) => {
        if (Array.isArray(v)) v.forEach(agregarCompetencia);
        else agregarCompetencia(v);
      });

      const compTrasfondoRaw = parsearJsonFlexible(trasfondo?.competencias, {});
      if (Array.isArray(compTrasfondoRaw)) compTrasfondoRaw.forEach(agregarCompetencia);
      if (compTrasfondoRaw && typeof compTrasfondoRaw === 'object') {
        const skillsFijas = Array.isArray(compTrasfondoRaw?.skills?.fixed) ? compTrasfondoRaw.skills.fixed : [];
        const tools = Array.isArray(compTrasfondoRaw?.tools || compTrasfondoRaw?.tool_proficiencies)
          ? (compTrasfondoRaw.tools || compTrasfondoRaw.tool_proficiencies)
          : [];
        skillsFijas.forEach(agregarCompetencia);
        tools.forEach(agregarCompetencia);
      }

      if (Array.isArray(idiomasConocidos)) idiomasConocidos.forEach((i) => competenciasPorTipo.idioma.add(traducirNombreProficiencia(normalizarRef(i))));
      if (Array.isArray(idiomasTrasfondo)) idiomasTrasfondo.forEach((i) => competenciasPorTipo.idioma.add(traducirNombreProficiencia(normalizarRef(i))));

      const filasCompetencias = [
        ['Armas', [...competenciasPorTipo.arma]],
        ['Armaduras', [...competenciasPorTipo.armadura]],
        ['Herramientas', [...competenciasPorTipo.herramienta]],
        ['Idiomas', [...competenciasPorTipo.idioma]],
        ['Otros', [...competenciasPorTipo.otros]]
      ];

      const filasHtml = filasCompetencias
        .filter(([, items]) => items.length > 0)
        .map(([tipo, items]) => `
          <tr>
            <th scope="row">${esc(tipo)}</th>
            <td>${esc(items
              .map((i) => String(i || '').trim())
              .filter(Boolean)
              .sort((a, b) => a.localeCompare(b, 'es'))
              .join(', '))}</td>
          </tr>
        `)
        .join('');

      competenciasEl.innerHTML = filasHtml
        ? `<table class="crear-paso4-table"><tbody>${filasHtml}</tbody></table>`
        : '<p class="crear-paso4-muted">Sin competencias registradas.</p>';
      function mod(valor) {
        if (typeof rulesHelper.calcularModificador === 'function') {
          return rulesHelper.calcularModificador(valor);
        }
        const n = Number(valor);
        if (!Number.isFinite(n)) return 0;
        return Math.floor((n - 10) / 2);
      }

      function fmtMod(n) {
        const v = Number(n) || 0;
        return `${v >= 0 ? '+' : ''}${v}`;
      }
      function normalizarTextoComparacion(txt = '') {
        return String(txt || '')
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim();
      }
      function normalizarSlugSkill(raw = '') {
        return String(raw || '')
          .trim()
          .toLowerCase()
          .replace(/^skills?[-_:]*/, '')
          .replace(/\s+/g, '-')
          .replace(/[^a-z0-9-]+/g, '-')
          .replace(/-+/g, '-')
          .replace(/^-+|-+$/g, '');
      }
      function resolverSkillSlug(raw = '') {
        const txt = String(raw || '').trim();
        if (!txt) return '';
        const bySlug = normalizarSlugSkill(txt);
        if (competenciaBySlug.has(bySlug)) return bySlug;
        const sinPrefijo = txt.replace(/^(skill|skills|habilidad|habilidades)\s*[:\-]\s*/i, '').trim();
        const bySlugSinPrefijo = normalizarSlugSkill(sinPrefijo);
        if (competenciaBySlug.has(bySlugSinPrefijo)) return bySlugSinPrefijo;
        const normNombre = String(sinPrefijo || txt)
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim();
        const fromNombre = competenciaSkillByNombreNorm.get(normNombre);
        return normalizarSlugSkill(fromNombre?.slug || bySlugSinPrefijo || bySlug);
      }

      function proficiencyBonus(nivel = 1) {
        if (typeof rulesHelper.calcularProficiencyBonus === 'function') {
          return rulesHelper.calcularProficiencyBonus(nivel);
        }
        const n = Math.max(1, Number(nivel) || 1);
        return 2 + Math.floor((n - 1) / 4);
      }

      const pb = proficiencyBonus(nivelTotal || 1);
      const SKILL_ATTR_BY_SLUG = {
        acrobatics: 'destreza',
        'animal-handling': 'sabiduria',
        arcana: 'inteligencia',
        athletics: 'fuerza',
        deception: 'carisma',
        history: 'inteligencia',
        insight: 'sabiduria',
        intimidation: 'carisma',
        investigation: 'inteligencia',
        medicine: 'sabiduria',
        nature: 'inteligencia',
        perception: 'sabiduria',
        performance: 'carisma',
        persuasion: 'carisma',
        religion: 'inteligencia',
        'sleight-of-hand': 'destreza',
        stealth: 'destreza',
        survival: 'sabiduria'
      };
      function normalizarAtributoSeguro(raw = '') {
        if (typeof rulesHelper.normalizarAtributo === 'function') {
          return rulesHelper.normalizarAtributo(raw);
        }
        const key = String(raw || '').trim().toLowerCase();
        const mapa = {
          str: 'fuerza',
          strength: 'fuerza',
          fuerza: 'fuerza',
          dex: 'destreza',
          dexterity: 'destreza',
          destreza: 'destreza',
          con: 'constitucion',
          constitution: 'constitucion',
          constitucion: 'constitucion',
          int: 'inteligencia',
          intelligence: 'inteligencia',
          inteligencia: 'inteligencia',
          wis: 'sabiduria',
          wisdom: 'sabiduria',
          sabiduria: 'sabiduria',
          cha: 'carisma',
          charisma: 'carisma',
          carisma: 'carisma'
        };
        return mapa[key] || '';
      }
      try {
        const skillsCatalogo = (Array.isArray(competenciasCatalogo) ? competenciasCatalogo : [])
          .filter((c) => {
            const tipo = String(c?.tipo || '').trim().toLowerCase();
            if (!['habilidad', 'skill', 'skills', 'habilidades'].includes(tipo)) return false;
            const slugSkill = resolverSkillSlug(c?.slug || c?.nombre);
            const atr = normalizarAtributoSeguro(c?.atributo) || SKILL_ATTR_BY_SLUG[slugSkill] || '';
            return ATRIBUTOS_VALIDOS.includes(atr);
          })
          .sort((a, b) => String(a?.nombre || '').localeCompare(String(b?.nombre || ''), 'es'));

        if (!skillsCatalogo.length) {
          habilidadesEl.innerHTML = '<p class="crear-paso4-muted">Sin catálogo de habilidades.</p>';
        } else {
          const rows = skillsCatalogo.map((s) => {
            const nombre = String(s?.nombre || '').trim();
            const slug = resolverSkillSlug(s?.slug || s?.nombre);
            const atr = normalizarAtributoSeguro(s?.atributo) || SKILL_ATTR_BY_SLUG[slug] || '';
            const base = mod(attrs?.[atr]);
            const competente = (slug && habilidadesCompetentesPorSlug.has(slug)) || habilidadesCompetentesPorNombre.has(normalizarTextoComparacion(nombre));
            const total = base + (competente ? pb : 0);
            const atrAbrev = (textosDirectos && atr ? (textosDirectos[`${atr}_abrev`] || atr) : '—');
            return `
              <tr>
                <td><span class="cp4-dot ${competente ? 'cp4-dot--filled' : 'cp4-dot--empty'}" aria-hidden="true"></span></td>
                <td>${esc(String(atrAbrev || '—'))}</td>
                <td>${esc(nombre || '—')}</td>
                <td>${esc(fmtMod(total))}</td>
              </tr>
            `;
          }).join('');
          habilidadesEl.innerHTML = `
            <table class="crear-paso4-table crear-paso4-skills-table">
              <thead>
                <tr>
                  <th>Comp.</th>
                  <th>Atributo</th>
                  <th>Habilidad</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>${rows}</tbody>
            </table>
          `;
        }
      } catch (error) {
        habilidadesEl.innerHTML = '<p class="crear-paso4-muted">No se pudieron calcular las habilidades.</p>';
      }

      function extraerAtributoDesdeSalvacion(raw = '') {
        const s = String(raw || '').trim().toLowerCase();
        if (!s) return '';
        if (s.includes('str') || s.includes('strength') || s.includes('fuerza')) return 'fuerza';
        if (s.includes('dex') || s.includes('dexterity') || s.includes('destreza')) return 'destreza';
        if (s.includes('con') || s.includes('constitution') || s.includes('constitucion')) return 'constitucion';
        if (s.includes('int') || s.includes('intelligence') || s.includes('inteligencia')) return 'inteligencia';
        if (s.includes('wis') || s.includes('wisdom') || s.includes('sabiduria')) return 'sabiduria';
        if (s.includes('cha') || s.includes('charisma') || s.includes('carisma')) return 'carisma';
        return '';
      }

      const salvacionesClaseRaw = aArraySeguro(clase?.tirada_salvacion);
      const salvacionesSet = new Set(
        salvacionesClaseRaw
          .map((item) => {
            const ref = String(item?.index || item?.name || item || '').trim();
            return extraerAtributoDesdeSalvacion(ref);
          })
          .filter(Boolean)
      );
      const salvacionesPaso2 = Array.isArray(resumenCompetenciasPaso2?.salvaciones) ? resumenCompetenciasPaso2.salvaciones : [];
      salvacionesPaso2.forEach((s) => {
        const atr = extraerAtributoDesdeSalvacion(s);
        if (atr) salvacionesSet.add(atr);
      });

      if (!salvacionesSet.size && competenciasPorTipo.salvacion.size) {
        [...competenciasPorTipo.salvacion].forEach((s) => {
          const atr = extraerAtributoDesdeSalvacion(s);
          if (atr) salvacionesSet.add(atr);
        });
      }

      try {
        const filasSalvacion = ATRIBUTOS_VALIDOS
          .map((atr) => {
            const nombre = textosDirectos?.[atr] || atr;
            const ok = salvacionesSet.has(atr);
            const total = mod(attrs?.[atr]) + (ok ? pb : 0);
            return `
              <tr>
                <td><span class="cp4-dot ${ok ? 'cp4-dot--filled' : 'cp4-dot--empty'}" aria-hidden="true"></span></td>
                <th scope="row">${esc(String(nombre))}</th>
                <td>${esc(fmtMod(total))}</td>
              </tr>
            `;
          })
          .join('');
        salvacionesEl.innerHTML = `
          <table class="crear-paso4-table crear-paso4-table--salvaciones">
            <colgroup>
              <col style="width:16%">
              <col style="width:64%">
              <col style="width:20%">
            </colgroup>
            <thead>
              <tr>
                <th>Comp.</th>
                <th>Salvación</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>${filasSalvacion}</tbody>
          </table>
        `;
      } catch (error) {
        salvacionesEl.innerHTML = '<p class="crear-paso4-muted">No se pudieron calcular las tiradas de salvación.</p>';
      }
    })();
  </script>
</body>
</html>
