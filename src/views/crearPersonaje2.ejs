      function danoArmaAlientoPorNivel(nivel = 1) {
        const n = Math.max(1, Number(nivel) || 1);
        if (n >= 16) return '5d6';
        if (n >= 11) return '4d6';
        if (n >= 6) return '3d6';
        return '2d6';
      }

      function nivelEscaladoArmaAliento(nivel = 1) {
        const n = Math.max(1, Number(nivel) || 1);
        if (n >= 16) return 16;
        if (n >= 11) return 11;
        if (n >= 6) return 6;
        return 1;
      }

      function resumenMejorasArmaAlientoPorNivel(nivel = 1) {
        const n = Math.max(1, Number(nivel) || 1);
        const hitos = [1, 6, 11, 16];
        return hitos
          .map((hito) => `${n >= hito ? '✓' : '○'} Nivel ${hito}: ${hito === 1 ? '2d6' : hito === 6 ? '3d6' : hito === 11 ? '4d6' : '5d6'}`)
          .join('\n');
      }

      function escapeHtml(texto = '') {
        return String(texto || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function obtenerEstadoCompetenciasRaciales() {
        const actual = seleccion?.competencias_raciales_elegidas;
        if (actual && typeof actual === 'object' && !Array.isArray(actual)) return actual;
        seleccion.competencias_raciales_elegidas = {};
        return seleccion.competencias_raciales_elegidas;
      }

      function extraerOpcionesCompetenciaRacial(modificadores, rasgoSlug = '') {
        const data = parsearJsonFlexible(modificadores, modificadores);
        const opciones = [];
        let cantidad = 0;

        function pushOpcion(item) {
          const slug = String(
            item?.item?.index ||
            item?.proficiency?.index ||
            item?.index ||
            item?.slug ||
            ''
          ).trim();
          const nombreRaw = String(
            item?.item?.name ||
            item?.proficiency?.name ||
            item?.name ||
            slug
          ).trim();
          if (!slug && !nombreRaw) return;
          const nombre = traducirNombreProficiencia(nombreRaw || slug);
          if (opciones.some((op) => op.slug === slug && op.nombre === nombre)) return;
          opciones.push({ slug: slug || nombre.toLowerCase().replace(/[^a-z0-9]+/g, '-'), nombre });
        }

        function recorrer(node) {
          if (!node) return;
          if (Array.isArray(node)) {
            node.forEach(recorrer);
            return;
          }
          if (typeof node === 'string') return;
          if (typeof node !== 'object') return;

          const type = String(node?.option_type || node?.type || '').toLowerCase();
          const choose = Number(node?.choose || node?.count || 0);
          if (type.includes('proficiency') && choose > 0) {
            cantidad = Math.max(cantidad, choose);
          }
          if (Array.isArray(node?.from?.options)) {
            if (choose > 0) cantidad = Math.max(cantidad, choose);
            node.from.options.forEach(pushOpcion);
          }
          if (Array.isArray(node?.options)) {
            if (choose > 0) cantidad = Math.max(cantidad, choose);
            node.options.forEach(pushOpcion);
          }
          if (Array.isArray(node?.proficiencies)) {
            if (choose > 0) cantidad = Math.max(cantidad, choose);
            node.proficiencies.forEach(pushOpcion);
          }
          if (node?.subtrait_options) recorrer(node.subtrait_options);
          if (node?.trait_specific) recorrer(node.trait_specific);
          if (node?.proficiency_choices) recorrer(node.proficiency_choices);
          Object.keys(node).forEach((k) => {
            if (['from', 'options', 'proficiencies', 'subtrait_options', 'trait_specific', 'proficiency_choices'].includes(k)) return;
            recorrer(node[k]);
          });
        }

        recorrer(data);

        // Fallback para casos sin estructura normalizada (ej: skill-versatility)
        if (!opciones.length && String(rasgoSlug || '').trim() === 'skill-versatility') {
          const skills = [
            'acrobatics',
            'animal-handling',
            'arcana',
            'athletics',
            'deception',
            'history',
            'insight',
            'intimidation',
            'investigation',
            'medicine',
            'nature',
            'perception',
            'performance',
            'persuasion',
            'religion',
            'sleight-of-hand',
            'stealth',
            'survival'
          ];
          skills.forEach((slug) => {
            const nombre = traducirNombreProficiencia(String(slug || '').trim());
            opciones.push({ slug, nombre });
          });
          cantidad = Math.max(cantidad, 2);
        }

        return { opciones, cantidad: Math.max(0, cantidad) };
      }

      function renderSelectorCompetenciaRacial({ rasgoSlug, opciones, cantidad, descripcion }) {
