<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
</head>
<body class="site">
  <%- include('partials/header') %>

  <main class="site-main">
    <div class="content-shell">
      <%- include('partials/crearPersonajePageHeader', { activeStep: 2 }) %>

      <div class="form-panel form-panel--wide form-panel--plain crear-personaje-panel--wide">
        <%- include('partials/crearPersonajeImagePickerCard', { imagenesDisponibles }) %>

        <section class="crear-paso2-grid" aria-label="Progresión por nivel de clase y raza">
          <article class="crear-paso2-panel">
            <div class="crear-paso2-panel__header">
              <div class="crear-paso2-panel__title-row">
                <div class="crear-paso2-panel__title-control">
                  <label class="crear-paso2-panel__label">Clase</label>
                  <select id="cp2-clase-select" class="crear-paso2-panel__title-select crear-paso2-native-select" aria-label="Seleccionar clase">
                    <option value="">Selecciona clase</option>
                    <% clases.forEach((clase) => { %>
                      <option value="<%= clase.slug %>"><%= clase.nombre %></option>
                    <% }) %>
                  </select>
                </div>
              </div>
              <div class="crear-paso2-overview" id="cp2-class-summary">
                <p class="crear-paso2-overview__level">
                  <strong>Nivel:</strong>
                  <span id="cp2-total-level">1</span>
                </p>
                <aside class="crear-paso2-vitals-card" aria-label="Resumen de vida">
                  <p class="crear-paso2-summary__item"><strong>Vida base estimada:</strong> <span id="cp2-hp-estimate">0</span></p>
                  <p class="crear-paso2-summary__item"><strong>Dados de vida:</strong> <span id="cp2-hit-dice">—</span></p>
                </aside>
              </div>
              <div id="cp2-multiclass-list" class="crear-paso2-multiclass-list"></div>
            </div>
            <div id="cp2-clase-cards" class="crear-paso2-card-list"></div>
            <div class="crear-paso2-panel__bottom-actions">
              <button type="button" id="cp2-add-class" class="btn btn-secondary">+ Añadir otra clase</button>
            </div>
            <section id="cp2-class-picker" class="crear-paso2-class-picker" hidden aria-label="Seleccionar clase">
              <div id="cp2-class-picker-list" class="crear-paso2-class-picker__list"></div>
            </section>
          </article>

          <article class="crear-paso2-panel">
            <div class="crear-paso2-panel__header">
              <div class="crear-paso2-panel__title-row">
                <div class="crear-paso2-panel__title-control">
                  <label for="cp2-raza-select" class="crear-paso2-panel__label">Raza</label>
                  <div class="crear-paso2-dropdown" id="cp2-raza-dropdown">
                    <button type="button" id="cp2-raza-trigger" class="crear-paso2-dropdown__trigger" aria-haspopup="listbox" aria-expanded="false">
                      <img class="crear-paso2-dropdown__img" src="/images/personajesDefecto/imagenPorDefecto.avif" alt="" />
                      <span class="crear-paso2-dropdown__text">Selecciona raza</span>
                    </button>
                    <div id="cp2-raza-menu" class="crear-paso2-dropdown__menu" role="listbox" hidden></div>
                  </div>
                  <select id="cp2-raza-select" class="crear-paso2-panel__title-select crear-paso2-native-select" aria-label="Seleccionar raza">
                    <option value="">Selecciona raza</option>
                    <% razas.forEach((raza) => { %>
                      <option value="<%= raza.slug %>"><%= raza.nombre %></option>
                    <% }) %>
                  </select>
                </div>

                <div id="cp2-subraza-control" class="crear-paso2-panel__sub-control crear-paso2-panel__title-control" hidden>
                  <label for="cp2-subraza-select" class="crear-paso2-panel__label">Subraza</label>
                  <select id="cp2-subraza-select" class="crear-paso2-panel__title-select" aria-label="Seleccionar subraza">
                    <option value="">Selecciona subraza</option>
                    <% subrazas.forEach((subraza) => { %>
                      <option value="<%= subraza.slug %>" data-raza-id="<%= subraza.RazaId %>"><%= subraza.nombre %></option>
                    <% }) %>
                  </select>
                </div>
              </div>
            </div>
            <div id="cp2-raza-cards" class="crear-paso2-card-list"></div>
          </article>
        </section>

        <div class="form-actions">
          <a href="/personajes/crear/1" class="btn btn-secondary">Anterior</a>
          <a href="/personajes/crear/3" class="btn btn-primary">Siguiente</a>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/avatarPickerToggleScript') %>
  <script id="cp2-clases-data" type="application/json"><%- JSON.stringify(clases).replace(/</g, '\\u003c') %></script>
  <script id="cp2-subclases-data" type="application/json"><%- JSON.stringify(subclases || []).replace(/</g, '\\u003c') %></script>
  <script id="cp2-subclase-niveles-data" type="application/json"><%- JSON.stringify(subclaseNiveles || []).replace(/</g, '\\u003c') %></script>
  <script id="cp2-razas-data" type="application/json"><%- JSON.stringify(razas).replace(/</g, '\\u003c') %></script>
  <script id="cp2-subrazas-data" type="application/json"><%- JSON.stringify(subrazas).replace(/</g, '\\u003c') %></script>
  <script id="cp2-clase-niveles-data" type="application/json"><%- JSON.stringify(claseNiveles || []).replace(/</g, '\\u003c') %></script>
  <script id="cp2-raza-niveles-data" type="application/json"><%- JSON.stringify(razaNiveles || []).replace(/</g, '\\u003c') %></script>
  <script id="cp2-idiomas-data" type="application/json"><%- JSON.stringify(idiomasCatalogo || []).replace(/</g, '\\u003c') %></script>
  <script id="cp2-rasgos-raciales-trad-data" type="application/json"><%- JSON.stringify(mapaRasgoRacial || {}).replace(/</g, '\\u003c') %></script>
  <script id="cp2-textos-directos-data" type="application/json"><%- JSON.stringify(textosDirectos || {}).replace(/</g, '\\u003c') %></script>
  <script id="cp2-feats-data" type="application/json"><%- JSON.stringify(featsCatalogo || []).replace(/</g, '\\u003c') %></script>
  <script>
    (function () {
      const STORAGE_SELECTION_KEY = 'crearPersonaje.seleccionPaso1';
      const STORAGE_ATTRS_KEY = 'crearPersonaje.atributosPaso3';
      const STORAGE_KNOWN_LANG_KEY = 'crearPersonaje.idiomasConocidosPaso2';
      const STORAGE_DRACONIC_ANCESTRY_KEY = 'crearPersonaje.ancestroDraconidoPaso2';
      const STORAGE_OPEN_CARDS_KEY = 'crearPersonaje.tarjetasAbiertasPaso2';
      const storage = window.sessionStorage;

      function parseJsonScript(id) {
        const el = document.getElementById(id);
        if (!el) return [];
        try {
          return JSON.parse(el.textContent || '[]');
        } catch {
          return [];
        }
      }

      function obtenerBaseScoresPaso3() {
        try {
          const raw = storage.getItem(STORAGE_ATTRS_KEY);
          return raw ? JSON.parse(raw) : {};
        } catch {
          return {};
        }
      }

      function parsearJsonFlexible(valor, fallback) {
        if (valor == null) return fallback;
        if (typeof valor === 'string') {
          const s = valor.trim();
          if (!s) return fallback;
          if ((s.startsWith('[') && s.endsWith(']')) || (s.startsWith('{') && s.endsWith('}'))) {
            try {
              return JSON.parse(s);
            } catch {
              return fallback;
            }
          }
          return fallback;
        }
        return valor;
      }

      function mapAtributo(idx = '') {
        const raw = String(idx || '').trim();
        const keyLower = raw.toLowerCase();
        // Abreviaturas de atributos en texto: vienen del JSON para evitar hardcodeo en EJS.
        return (textosDirectos && (textosDirectos[keyLower] || textosDirectos[raw])) || raw.toUpperCase();
      }

      function traducirNombreProficiencia(name = '') {
        const keyRaw = String(name || '').trim();
        if (!keyRaw) return '';
        const sinPrefijo = keyRaw.replace(/^(skill|saving throw|saving throws|tool|tools|instrument|instruments|language|languages|weapon|weapons|armor|armour)\s*:\s*/i, '').trim();
        const keyLower = keyRaw.toLowerCase();
        const sinPrefijoLower = sinPrefijo.toLowerCase();
        const keySlug = keyLower.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
        const sinPrefijoSlug = sinPrefijoLower.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

        const traducido =
          (textosDirectos && (
            textosDirectos[keyRaw] ||
            textosDirectos[sinPrefijo] ||
            textosDirectos[keyLower] ||
            textosDirectos[sinPrefijoLower] ||
            textosDirectos[keySlug] ||
            textosDirectos[sinPrefijoSlug]
          )) ||
          '';
        if (traducido) return String(traducido).trim();
        const idiomaSlug = normalizarIdiomaSlug(sinPrefijo || keyRaw);
        const idiomaFallback = {
          common: 'Común',
          dwarvish: 'Enano',
          elvish: 'Élfico',
          giant: 'Gigante',
          gnomish: 'Gnomo',
          goblin: 'Góblin',
          halfling: 'Mediano',
          orc: 'Orco',
          abyssal: 'Abisal',
          celestial: 'Celestial',
          draconic: 'Dracónico',
          'deep-speech': 'Lengua profunda',
          infernal: 'Infernal',
          primordial: 'Primordial',
          sylvan: 'Silvano',
          undercommon: 'Infracomún'
        };
        if (idiomaFallback[idiomaSlug]) return idiomaFallback[idiomaSlug];
        return sinPrefijo || keyRaw;
      }

      function obtenerEstadoCompetenciasClase() {
        const actual = seleccion?.competencias_clase_elegidas;
        if (actual && typeof actual === 'object' && !Array.isArray(actual)) return actual;
        seleccion.competencias_clase_elegidas = {};
        return seleccion.competencias_clase_elegidas;
      }

      function categoriaCompetencia(item) {
        const idx = String(item?.index || '').toLowerCase();
        const name = String(item?.name || '').toLowerCase();
        const texto = `${idx} ${name}`;
        if (idx.includes('saving-throw')) return 'Tiradas de salvación';
        if (idx.includes('armor') || idx === 'shields') return 'Armaduras';
        if (idx.includes('tool') || idx.includes('kit') || idx.includes('instrument')) return 'Herramientas';
        if (
          texto.includes('weapon') ||
          texto.includes('sword') ||
          texto.includes('bow') ||
          texto.includes('crossbow') ||
          texto.includes('dagger') ||
          texto.includes('mace') ||
          texto.includes('spear') ||
          texto.includes('club') ||
          texto.includes('staff') ||
          texto.includes('sling') ||
          texto.includes('javelin') ||
          texto.includes('scimitar') ||
          texto.includes('darts') ||
          texto.includes('rapier') ||
          texto.includes('sickle')
        ) return 'Armas';
        return 'Otros';
      }

      function formatearTiradasSalvacionClase(valor) {
        const lista = Array.isArray(parsearJsonFlexible(valor, valor)) ? parsearJsonFlexible(valor, valor) : [];
        if (!lista.length) return [];
        return lista
          .map((item) => {
            const bruto = String(item?.name || item?.index || item || '').trim();
            if (!bruto) return '';
            return traducirNombreProficiencia(bruto);
          })
          .filter(Boolean);
      }

      function extraerOpcionesCompetenciaClase(choice) {
        const opciones = [];
        function pushOpcion(item) {
          const slug = String(
            item?.item?.index ||
            item?.proficiency?.index ||
            item?.index ||
            item?.slug ||
            ''
          ).trim();
          const nombreRaw = String(
            item?.item?.name ||
            item?.proficiency?.name ||
            item?.name ||
            slug
          ).trim();
          if (!slug && !nombreRaw) return;
          const nombre = traducirNombreProficiencia(nombreRaw || slug);
          if (opciones.some((op) => op.slug === slug && op.nombre === nombre)) return;
          opciones.push({ slug: slug || nombre.toLowerCase().replace(/[^a-z0-9]+/g, '-'), nombre });
        }
        function recorrer(node) {
          if (!node) return;
          if (Array.isArray(node)) {
            node.forEach(recorrer);
            return;
          }
          if (typeof node !== 'object') return;
          if (node?.item || node?.proficiency) {
            pushOpcion(node);
          }
          if (Array.isArray(node?.options)) node.options.forEach(recorrer);
          if (Array.isArray(node?.from?.options)) node.from.options.forEach(recorrer);
          if (Array.isArray(node?.from)) node.from.forEach(recorrer);
        }
        recorrer(choice?.from || choice);
        const textoChoice = JSON.stringify(choice || {}).toLowerCase();
        const tieneInstrumento = opciones.some((op) => {
          const t = `${String(op?.slug || '').toLowerCase()} ${String(op?.nombre || '').toLowerCase()}`;
          return t.includes('instrument') || t.includes('bagpipes') || t.includes('drum') || t.includes('flute') || t.includes('lute') || t.includes('lyre') || t.includes('horn') || t.includes('pan') || t.includes('shawm') || t.includes('viol');
        }) || textoChoice.includes('instrument') || textoChoice.includes('musical');
        const tieneHabilidad = opciones.some((op) => {
          const t = `${String(op?.slug || '').toLowerCase()} ${String(op?.nombre || '').toLowerCase()}`;
          return t.includes('skill') || t.includes('acrobatics') || t.includes('athletics') || t.includes('stealth') || t.includes('perception');
        }) || textoChoice.includes('skill');
        const tieneHerramienta = !tieneInstrumento && (opciones.some((op) => {
          const t = `${String(op?.slug || '').toLowerCase()} ${String(op?.nombre || '').toLowerCase()}`;
          return t.includes('tool') || t.includes('kit') || t.includes('tools');
        }) || textoChoice.includes('tool') || textoChoice.includes('kit'));

        const tipo = tieneInstrumento ? 'Instrumento' : (tieneHabilidad ? 'Habilidad' : (tieneHerramienta ? 'Herramienta' : 'Competencia'));
        return { opciones, tipo };
      }

      function renderSelectorCompetenciaClase({ key, opciones, cantidad, tipo = 'Competencia' }) {
        const estado = obtenerEstadoCompetenciasClase();
        const previas = Array.isArray(estado[key]) ? estado[key] : [];
        const total = Math.max(1, Number(cantidad) || 1);
        const tipoLower = String(tipo || 'Competencia').toLowerCase();
        const filas = Array.from({ length: total }, (_, idx) => {
          const selected = String(previas[idx] || '').trim();
          const seleccionadosOtros = new Set(
            previas
              .map((v, i) => (i === idx ? '' : String(v || '').trim()))
              .filter(Boolean)
          );
          const opts = opciones
            .filter((op) => op.slug === selected || !seleccionadosOtros.has(op.slug))
            .map((op) => `
              <option value="${escapeHtml(op.slug)}" ${op.slug === selected ? 'selected' : ''}>${escapeHtml(op.nombre)}</option>
            `).join('');
          return `
            <div class="crear-paso2-ancestor-choice-row">
              <label class="crear-paso2-ancestor-label" for="cp2-class-choice-${escapeHtml(key)}-${idx}">${escapeHtml(tipo)} ${idx + 1}</label>
              <select
                id="cp2-class-choice-${escapeHtml(key)}-${idx}"
                class="crear-paso2-panel__title-select cp2-class-choice-select"
                data-class-choice-key="${escapeHtml(key)}"
                data-choice-idx="${idx}"
              >
                <option value="">Selecciona ${escapeHtml(tipoLower)}</option>
                ${opts}
              </select>
            </div>
          `;
        }).join('');
        return filas;
      }

      function formatearCompetenciasClase(valor, tiradasSalvacion = null, claseSlug = '', proficiencyChoicesRaw = null) {
        const data = parsearJsonFlexible(valor, valor) || {};
        const profs = Array.isArray(data?.proficiencies) ? data.proficiencies : [];
        const proficiencyChoices = Array.isArray(proficiencyChoicesRaw)
          ? proficiencyChoicesRaw
          : (Array.isArray(data?.proficiency_choices) ? data.proficiency_choices : []);
        const grupos = new Map();
        profs.forEach((p) => {
          const categoria = categoriaCompetencia(p);
          const nombre = traducirNombreProficiencia(String(p?.name || p?.index || ''));
          if (!nombre) return;
          if (!grupos.has(categoria)) grupos.set(categoria, []);
          grupos.get(categoria).push(nombre);
        });
        const salvaciones = formatearTiradasSalvacionClase(tiradasSalvacion);
        if (salvaciones.length) {
          grupos.set('Tiradas de salvación', salvaciones);
        }
        const tieneLineasFijas = grupos.size > 0;
        const orden = ['Armaduras', 'Armas', 'Herramientas', 'Tiradas de salvación', 'Otros'];
        const lineas = [];
        orden.forEach((cat) => {
          const items = grupos.get(cat);
          if (!items || !items.length) return;
          lineas.push(`<strong>${cat}:</strong> ${items.join(', ')}`);
        });
        const eleccionesHtml = proficiencyChoices
          .map((choice, choiceIdx) => {
            const cantidad = Number(choice?.choose || choice?.count || 0);
            if (!cantidad) return '';
            const { opciones, tipo } = extraerOpcionesCompetenciaClase(choice);
            if (!Array.isArray(opciones) || !opciones.length) return '';
            const key = `clase:${String(claseSlug || '')}:prof-choice:${choiceIdx}`;
            const filas = renderSelectorCompetenciaClase({ key, opciones, cantidad, tipo });
            const tipoLower = String(tipo || 'Competencia').toLowerCase();
            return `
              <p class="crear-paso2-ancestor-label">Elige ${cantidad} ${escapeHtml(tipoLower)}${cantidad > 1 ? 's' : ''}:</p>
              ${filas}
            `;
          })
          .filter(Boolean)
          .join('');

        if (!tieneLineasFijas && !eleccionesHtml) return 'Sin datos de competencias.';
        return `${lineas.join('<br>')}${eleccionesHtml ? `<div class="cp2-class-proficiency-choices">${eleccionesHtml}</div>` : ''}`;
      }

      function formatearBonificadores(mods) {
        if (typeof mods === 'string') {
          const txt = mods.trim();
          if (txt) return txt;
        }
        const lista = Array.isArray(parsearJsonFlexible(mods, mods)) ? parsearJsonFlexible(mods, mods) : [];
        if (!lista.length) return 'Sin bonificadores.';
        return lista
          .map((b) => {
            const idx = b?.ability_score?.index || b?.ability_score?.name || '';
            const bonus = Number(b?.bonus) || 0;
            return `${mapAtributo(idx)} ${bonus >= 0 ? '+' : ''}${bonus}`;
          })
          .join(', ');
      }

      function obtenerEstadoBonificadoresRaciales() {
        const actual = seleccion?.bonificadores_raciales_elegidos;
        if (actual && typeof actual === 'object' && !Array.isArray(actual)) return actual;
        seleccion.bonificadores_raciales_elegidos = {};
        return seleccion.bonificadores_raciales_elegidos;
      }

      function analizarBonificadoresRaciales(mods) {
        const lista = Array.isArray(parsearJsonFlexible(mods, mods)) ? parsearJsonFlexible(mods, mods) : [];
        const fijos = [];
        const elecciones = [];
        lista.forEach((b) => {
          const idxRaw = String(b?.ability_score?.index || b?.ability_score?.name || '').trim().toLowerCase();
          const bonus = Number(b?.bonus) || 0;
          if (!bonus) return;
          if (idxRaw === 'choice') {
            elecciones.push(bonus);
            return;
          }
          fijos.push(`${mapAtributo(idxRaw)} ${bonus >= 0 ? '+' : ''}${bonus}`);
        });
        return { fijos, elecciones };
      }

      function descripcionEleccionesBonificador(elecciones = []) {
        const lista = Array.isArray(elecciones) ? elecciones.map((v) => Number(v) || 0).filter((v) => v > 0) : [];
        if (!lista.length) return 'Bonificadores a elección.';
        const todosMasUno = lista.every((v) => v === 1);
        if (todosMasUno && lista.length > 1) {
          return `${lista.length} bonificadores de +1 en atributos diferentes.`;
        }
        return 'Bonificadores a elección.';
      }

      function renderSelectorBonificadorRacial({ key, elecciones = [], descripcion = '' }) {
        const estado = obtenerEstadoBonificadoresRaciales();
        const previas = Array.isArray(estado[key]) ? estado[key] : [];
        const totalesActuales = calcularTotalesConAsiPaso2();
        const opcionesBase = [
          ['fuerza', 'Fuerza'],
          ['destreza', 'Destreza'],
          ['constitucion', 'Constitución'],
          ['inteligencia', 'Inteligencia'],
          ['sabiduria', 'Sabiduría'],
          ['carisma', 'Carisma']
        ];
        const filas = elecciones.map((bonus, idx) => {
          const bonusNum = Number(bonus) || 0;
          const selected = String(previas[idx] || '').trim();
          const seleccionadosEnOtros = new Set(
            previas
              .map((val, i) => (i === idx ? '' : String(val || '').trim()))
              .filter(Boolean)
          );
          const opcionesFila = opcionesBase.filter(([slug]) => {
            if (slug !== selected && seleccionadosEnOtros.has(slug)) return false;
            const totalActual = Number(totalesActuales?.[slug] || 0);
            const ajusteSeleccionActual = slug === selected ? bonusNum : 0;
            const totalProyectado = totalActual + bonusNum - ajusteSeleccionActual;
            return totalProyectado <= 20;
          });
          const opts = opcionesFila.map(([slug, nombre]) => `
            <option value="${escapeHtml(slug)}" ${slug === selected ? 'selected' : ''}>${escapeHtml(nombre)}</option>
          `).join('');
          const bonusLabel = `${bonusNum >= 0 ? '+' : ''}${bonusNum}`;
          return `
            <div class="crear-paso2-ancestor-choice-row">
              <label class="crear-paso2-ancestor-label" for="cp2-race-ability-choice-${escapeHtml(key)}-${idx}">Bonificador ${idx + 1} (${bonusLabel})</label>
              <select
                id="cp2-race-ability-choice-${escapeHtml(key)}-${idx}"
                class="crear-paso2-panel__title-select cp2-race-choice-select cp2-race-ability-choice-select"
                data-bonus-key="${escapeHtml(key)}"
                data-choice-idx="${idx}"
              >
                <option value="">Selecciona atributo</option>
                ${opts}
              </select>
            </div>
          `;
        }).join('');
        const desc = escapeHtml(String(descripcion || '').trim() || 'Sin descripción disponible.');
        return `
          <p>${desc}</p>
          <p class="crear-paso2-ancestor-label">Elige ${elecciones.length} atributo${elecciones.length > 1 ? 's' : ''} para aplicar bonificadores:</p>
          ${filas}
        `;
      }

      function obtenerBonificadoresRazaPaso2({ fila, razaSeleccionada, subrazaSeleccionada }) {
        const bonosFila = parsearJsonFlexible(fila?.modificadores, null);
        if (Array.isArray(bonosFila) && bonosFila.length) return bonosFila;

        const slugRaza = String(razaSeleccionada?.slug || '').trim().toLowerCase();
        const bonosSubraza = parsearJsonFlexible(subrazaSeleccionada?.bonuses, null);
        if (slugRaza === 'human' && Array.isArray(bonosSubraza) && bonosSubraza.length) {
          return bonosSubraza;
        }

        const bonosRaza = parsearJsonFlexible(razaSeleccionada?.bonuses, []);
        if (Array.isArray(bonosRaza) && bonosRaza.length) return bonosRaza;

        return Array.isArray(bonosSubraza) ? bonosSubraza : [];
      }

      function formatearIdiomas(idiomas) {
        if (typeof idiomas === 'string') {
          const txt = idiomas.trim();
          if (txt) return txt;
        }
        const lista = Array.isArray(parsearJsonFlexible(idiomas, idiomas)) ? parsearJsonFlexible(idiomas, idiomas) : [];
        if (!lista.length) return 'Sin datos de idiomas.';
        return lista.map((i) => {
          const idx = String(typeof i === 'string' ? i : (i?.index || '')).trim().toLowerCase();
          const name = String(typeof i === 'string' ? '' : (i?.name || '')).trim();
          const base = name || idx;
          return traducirNombreProficiencia(base);
        }).filter(Boolean).join(', ');
      }

      function slugIdiomaDesdeTexto(valor = '') {
        const t = String(valor || '').trim().toLowerCase();
        const mapa = {
          common: 'common',
          'comun': 'common',
          dwarvish: 'dwarvish',
          enano: 'dwarvish',
          elvish: 'elvish',
          'elfico': 'elvish',
          giant: 'giant',
          gnomish: 'gnomish',
          gnomo: 'gnomish',
          goblin: 'goblin',
          halfling: 'halfling',
          mediano: 'halfling',
          orc: 'orc',
          orco: 'orc',
          abyssal: 'abyssal',
          abisal: 'abyssal',
          celestial: 'celestial',
          draconic: 'draconic',
          draconico: 'draconic',
          'deep speech': 'deep-speech',
          infernal: 'infernal',
          primordial: 'primordial',
          sylvan: 'sylvan',
          silvano: 'sylvan',
          undercommon: 'undercommon',
          'infracomun': 'undercommon'
        };
        return mapa[t] || t.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      }
      function normalizarIdiomaSlug(valor = '') {
        return slugIdiomaDesdeTexto(valor);
      }

      function preguardarIdiomasConocidos(razaSeleccionada, subrazaSeleccionada) {
        const conocidos = new Set();
        const fuentes = [razaSeleccionada?.idiomas, subrazaSeleccionada?.idiomas];
        fuentes.forEach((fuente) => {
          const lista = parsearJsonFlexible(fuente, fuente);
          if (!Array.isArray(lista)) return;
          lista.forEach((item) => {
            const raw = typeof item === 'string'
              ? item
              : (item?.index || item?.name || item?.slug || item?.nombre || '');
            const idioma = normalizarIdiomaSlug(raw);
            if (idioma) conocidos.add(idioma);
          });
        });
        const idiomasRacialesElegidos = Array.isArray(seleccion?.idiomas_raciales_elegidos)
          ? seleccion.idiomas_raciales_elegidos
          : [];
        idiomasRacialesElegidos.forEach((item) => {
          const idioma = normalizarIdiomaSlug(item);
          if (idioma) conocidos.add(idioma);
        });
        if (!conocidos.size) conocidos.add('common');
        storage.setItem(STORAGE_KNOWN_LANG_KEY, JSON.stringify(Array.from(conocidos)));
      }

      function obtenerEstadoIdiomasRaciales() {
        const actual = seleccion?.idiomas_raciales_elegidos;
        if (Array.isArray(actual)) return actual;
        seleccion.idiomas_raciales_elegidos = [];
        return seleccion.idiomas_raciales_elegidos;
      }

      function normalizarIdiomasRacialesConfig(rawIdiomas, razaSlug = '') {
        const data = parsearJsonFlexible(rawIdiomas, rawIdiomas);
        const fixed = [];
        let choose = 0;
        let options = [];
        if (Array.isArray(data)) {
          data.forEach((item) => {
            const txt = String(item?.name || item?.index || item || '').trim();
            if (txt) fixed.push(txt);
          });
        } else if (data && typeof data === 'object') {
          const fixedRaw = Array.isArray(data.fixed) ? data.fixed : [];
          fixedRaw.forEach((item) => {
            const txt = String(item?.name || item?.index || item || '').trim();
            if (txt) fixed.push(txt);
          });
          choose = Math.max(0, Number(data.choose || data.count || 0) || 0);
          const optionsRaw = Array.isArray(data.options) ? data.options : [];
          options = optionsRaw.map((item) => String(item?.name || item?.index || item || '').trim()).filter(Boolean);
        }
        if (choose <= 0 && String(razaSlug || '').trim().toLowerCase() === 'human') {
          choose = 1;
        }
        if (String(razaSlug || '').trim().toLowerCase() === 'human' && !fixed.length) {
          fixed.push('common');
        }
        if (!options.length && choose > 0) {
          options = (Array.isArray(idiomasCatalogo) ? idiomasCatalogo : [])
            .map((i) => String(i?.slug || i?.nombre || '').trim())
            .filter(Boolean)
            .filter((txt) => normalizarIdiomaSlug(txt) !== 'common');
        }
        return { fixed, choose, options };
      }

