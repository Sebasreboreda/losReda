        if (text) text.textContent = nombre || placeholder;
      }

      function inicializarDropdownCatalogo({ selectEl, triggerEl, menuEl, mapBySlug, lista, placeholder }) {
        menuEl.innerHTML = '';
        (Array.isArray(lista) ? lista : []).forEach((item) => {
          const slug = String(item?.slug || '').trim();
          if (!slug) return;
          const nombre = String(item?.nombre || slug).trim();
          const imagen = String(item?.imagenUrl || '/images/personajesDefecto/imagenPorDefecto.avif').trim();
          const option = document.createElement('button');
          option.type = 'button';
          option.className = 'crear-paso2-dropdown__option';
          option.setAttribute('role', 'option');
          option.dataset.slug = slug;
          option.innerHTML = `
            <img class="crear-paso2-dropdown__option-img" src="${imagen}" alt="" loading="lazy" />
            <span class="crear-paso2-dropdown__option-text">${nombre}</span>
          `;
          option.addEventListener('click', () => {
            selectEl.value = slug;
            selectEl.dispatchEvent(new Event('change'));
            cerrarMenusCatalogo();
          });
          menuEl.appendChild(option);
        });

        triggerEl.addEventListener('click', (event) => {
          event.stopPropagation();
          const abierto = !menuEl.hasAttribute('hidden');
          cerrarMenusCatalogo();
          if (!abierto) {
            menuEl.removeAttribute('hidden');
            triggerEl.setAttribute('aria-expanded', 'true');
          }
        });

        selectEl.addEventListener('change', () => {
          actualizarTriggerCatalogo({ selectEl, triggerEl, mapBySlug, placeholder });
        });
        actualizarTriggerCatalogo({ selectEl, triggerEl, mapBySlug, placeholder });
      }

      function normalizarMulticlases() {
        const raw = Array.isArray(seleccion.multiclases) ? seleccion.multiclases : [];
        const usadas = new Set();
        const lista = [];
        raw.forEach((fila) => {
          const slug = String(fila?.slug || '').trim();
          const nivel = Math.max(1, Math.min(20, Number(fila?.nivel) || 1));
          if (!slug || !claseBySlug.has(slug) || usadas.has(slug)) return;
          usadas.add(slug);
          const subclaseSlug = String(fila?.subclase || '').trim();
          const subclase = subclaseBySlug.get(subclaseSlug);
          const clase = claseBySlug.get(slug);
          const subclaseValida = subclase && Number(subclase?.ClaseId) === Number(clase?.id) ? subclaseSlug : '';
          lista.push({ slug, nivel, subclase: subclaseValida });
        });

        if (!lista.length) {
          const slugBase = String(seleccion.clase || '').trim();
          if (slugBase && claseBySlug.has(slugBase)) {
            lista.push({ slug: slugBase, nivel: 1, subclase: '' });
          }
        }

        if (lista.length) {
          const slugActivo = String(seleccion.clase || '').trim();
          if (!slugActivo || !lista.some((fila) => fila.slug === slugActivo)) {
            seleccion.clase = lista[0].slug;
          }
        } else {
          delete seleccion.clase;
        }

        seleccion.multiclases = lista;
      }

      function obtenerMulticlases() {
        normalizarMulticlases();
        return Array.isArray(seleccion.multiclases) ? seleccion.multiclases : [];
      }

      function nivelTotalPersonaje() {
        return obtenerMulticlases().reduce((acc, fila) => acc + (Number(fila?.nivel) || 0), 0);
      }

      function nivelMaximoParaClase(slug) {
        const clasesActuales = obtenerMulticlases();
        const resto = clasesActuales
          .filter((fila) => fila.slug !== slug)
          .reduce((acc, fila) => acc + (Number(fila?.nivel) || 0), 0);
        return Math.max(1, 20 - resto);
      }

      function actualizarNivelClase(slug, nivelNuevo) {
        const lista = obtenerMulticlases();
        if (!lista.some((item) => item.slug === slug)) return;
        const maxNivel = nivelMaximoParaClase(slug);
        const nivelNormalizado = Math.max(1, Math.min(maxNivel, Number(nivelNuevo) || 1));
        seleccion.multiclases = lista.map((item) => (
          item.slug === slug
            ? { ...item, nivel: nivelNormalizado }
            : item
        ));
      }

      function obtenerSubclasesDeClase(claseSeleccionada) {
        const claseId = Number(claseSeleccionada?.id) || 0;
        const lista = Array.isArray(subclasesByClaseId.get(claseId)) ? subclasesByClaseId.get(claseId) : [];
        return lista.slice().sort((a, b) => String(a?.nombre || '').localeCompare(String(b?.nombre || ''), 'es'));
      }

      function obtenerEtiquetaTipoSubclase(claseSeleccionada) {
        const opciones = obtenerSubclasesDeClase(claseSeleccionada);
        const contador = new Map();
        opciones.forEach((sub) => {
          const tipo = String(sub?.tipo_subclase || '').trim();
          if (!tipo) return;
          contador.set(tipo, (contador.get(tipo) || 0) + 1);
        });
        if (!contador.size) return 'Subclase';
        return Array.from(contador.entries())
          .sort((a, b) => b[1] - a[1] || String(a[0]).localeCompare(String(b[0]), 'es'))[0][0];
      }

      function obtenerNivelDesbloqueoSubclase(claseSeleccionada) {
        if (!claseSeleccionada) return null;
        const opcionesSubclase = obtenerSubclasesDeClase(claseSeleccionada);
        if (!opcionesSubclase.length) return null;
        const subIds = new Set(opcionesSubclase.map((s) => Number(s?.id)).filter(Boolean));
        const niveles = (Array.isArray(subclaseNiveles) ? subclaseNiveles : [])
          .filter((fila) => subIds.has(Number(fila?.SubclaseId)))
          .map((fila) => Number(fila?.nivel))
          .filter((n) => Number.isFinite(n) && n > 0);
        if (!niveles.length) return 1;
        return Math.min(...niveles);
      }

      function actualizarSubclaseClase(slugClase, subclaseSlug) {
        const clase = claseBySlug.get(String(slugClase || '').trim());
        if (!clase) return;
        const nueva = String(subclaseSlug || '').trim();
        const sub = subclaseBySlug.get(nueva);
        const valido = sub && Number(sub?.ClaseId) === Number(clase?.id) ? nueva : '';
        const nivelDesbloqueo = obtenerNivelDesbloqueoSubclase(clase);
        seleccion.multiclases = obtenerMulticlases().map((fila) => {
          if (fila.slug !== slugClase) return fila;
          const nivelClase = Number(fila?.nivel) || 1;
          if (!nivelDesbloqueo || nivelClase < nivelDesbloqueo) {
            return { ...fila, subclase: '' };
          }
          return { ...fila, subclase: valido };
        });
      }

      function calcularVidaBaseEstimada() {
        const clasesActuales = obtenerMulticlases();
        if (!clasesActuales.length) return 0;
        let total = 0;
        clasesActuales.forEach((fila, idx) => {
          const clase = claseBySlug.get(fila.slug);
          const dado = Number(clase?.dado_vida) || 0;
          const nivel = Number(fila?.nivel) || 0;
          if (dado < 1 || nivel < 1) return;
          const promedio = Math.floor(dado / 2) + 1;
          if (idx === 0) {
            total += dado;
            if (nivel > 1) total += (nivel - 1) * promedio;
          } else {
            total += nivel * promedio;
          }
        });
        return total;
      }

      function construirTextoDadosVida() {
        const acumulado = new Map();
        obtenerMulticlases().forEach((fila) => {
          const clase = claseBySlug.get(fila.slug);
          const dado = Number(clase?.dado_vida) || 0;
          const nivel = Number(fila?.nivel) || 0;
          if (dado < 1 || nivel < 1) return;
          const key = `d${dado}`;
          acumulado.set(key, (acumulado.get(key) || 0) + nivel);
        });
        if (!acumulado.size) return '—';
        return Array.from(acumulado.entries())
          .sort((a, b) => Number(a[0].slice(1)) - Number(b[0].slice(1)))
          .map(([die, count]) => `${count}${die}`)
          .join(' + ');
      }

      function renderResumenClase() {
        totalLevelEl.textContent = String(nivelTotalPersonaje());
        hpEstimateEl.textContent = String(calcularVidaBaseEstimada());
        hitDiceEl.textContent = construirTextoDadosVida();
      }

      function renderClassPicker() {
        classPickerListEl.innerHTML = '';
        const seleccionadas = new Set(obtenerMulticlases().map((fila) => fila.slug));
        const nivelTotal = nivelTotalPersonaje();
        if (nivelTotal >= 20) {
          const empty = document.createElement('p');
          empty.className = 'crear-paso2-empty';
          empty.textContent = 'Has alcanzado el nivel total 20.';
          classPickerListEl.appendChild(empty);
          return;
        }

        let disponibles = 0;
        clases.forEach((clase) => {
          const slug = String(clase?.slug || '').trim();
          if (!slug || seleccionadas.has(slug)) return;
          disponibles += 1;
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'crear-personaje-catalog-item';
          btn.innerHTML = `
            <img class="crear-personaje-catalog-item__img" src="${String(clase?.imagenUrl || '/images/personajesDefecto/imagenPorDefecto.avif')}" alt="" loading="lazy" />
            <h3>${String(clase?.nombre || slug)}</h3>
          `;
          btn.addEventListener('click', () => {
            const actuales = obtenerMulticlases();
            if (actuales.some((fila) => fila.slug === slug)) return;
            if (nivelTotalPersonaje() >= 20) return;
            actuales.push({ slug, nivel: 1, subclase: '' });
            seleccion.multiclases = actuales;
            seleccion.clase = slug;
            claseSelect.value = slug;
            claseSelect.dispatchEvent(new Event('change'));
            classPickerEl.setAttribute('hidden', '');
          });
          classPickerListEl.appendChild(btn);
        });

        if (!disponibles) {
          const empty = document.createElement('p');
          empty.className = 'crear-paso2-empty';
          empty.textContent = 'No hay clases disponibles para añadir.';
          classPickerListEl.appendChild(empty);
        }
      }

      function renderListaMulticlase() {
        multiclassListEl.innerHTML = '';
        const lista = obtenerMulticlases();
        if (!lista.length) return;
        lista.forEach((fila) => {
          const clase = claseBySlug.get(fila.slug);
          if (!clase) return;
          const row = document.createElement('div');
          row.className = 'crear-paso2-multiclass-item';
          const isActive = fila.slug === String(seleccion.clase || '').trim();
          row.classList.toggle('is-active', isActive);

          row.innerHTML = `
            <div class="crear-paso2-multiclass-item__name">
              <img class="crear-paso2-multiclass-item__img" src="${String(clase?.imagenUrl || '/images/personajesDefecto/imagenPorDefecto.avif')}" alt="" loading="lazy" />
              <span>${String(clase?.nombre || fila.slug)}</span>
            </div>
          `;

          const maxNivel = nivelMaximoParaClase(fila.slug);
          const nivelActual = Math.max(1, Math.min(maxNivel, Number(fila.nivel) || 1));
          fila.nivel = nivelActual;

          const levelWrap = document.createElement('div');
          levelWrap.className = 'crear-paso2-multiclass-item__level';
          const levelLabel = document.createElement('label');
          levelLabel.textContent = 'Nivel';
          const levelSelectEl = document.createElement('select');
          levelSelectEl.className = 'crear-paso2-multiclass-item__level-select';
          for (let i = 1; i <= maxNivel; i += 1) {
            const opt = document.createElement('option');
            opt.value = String(i);
            opt.textContent = String(i);
            if (i === nivelActual) opt.selected = true;
            levelSelectEl.appendChild(opt);
          }
          const onNivelChange = (event) => {
            event.stopPropagation();
            actualizarNivelClase(fila.slug, levelSelectEl.value);
            guardarSeleccion();
            render();
          };
          levelSelectEl.addEventListener('change', onNivelChange);
          levelSelectEl.addEventListener('input', onNivelChange);
          levelWrap.appendChild(levelLabel);
          levelWrap.appendChild(levelSelectEl);
          row.appendChild(levelWrap);

          const deleteBtn = document.createElement('button');
          deleteBtn.type = 'button';
          deleteBtn.className = 'crear-paso2-multiclass-item__delete';
          deleteBtn.setAttribute('aria-label', `Eliminar clase ${String(clase?.nombre || fila.slug)}`);
          deleteBtn.textContent = '×';
          deleteBtn.addEventListener('click', () => {
            const restantes = obtenerMulticlases().filter((item) => item.slug !== fila.slug);
            seleccion.multiclases = restantes;
            if (!restantes.length) {
              delete seleccion.clase;
              claseSelect.value = '';
            } else if (String(seleccion.clase || '').trim() === fila.slug) {
              seleccion.clase = restantes[0].slug;
              claseSelect.value = restantes[0].slug;
            }
            render();
          });
          row.appendChild(deleteBtn);

          multiclassListEl.appendChild(row);
        });
      }

      function contraerTarjetasDentro(container) {
        Array.from(container.querySelectorAll('.crear-paso2-card')).forEach((card) => {
          card.setAttribute('aria-expanded', 'false');
          card.classList.remove('is-open');
          const detail = card.querySelector('.crear-paso2-card__detail');
          if (detail) detail.hidden = true;
          const toggle = card.querySelector('.crear-paso2-drawer__toggle');
          if (toggle) toggle.setAttribute('aria-expanded', 'false');
        });
        const scopeKey = String(container?.dataset?.openScope || '').trim();
        if (scopeKey) {
          const estado = obtenerEstadoTarjetasAbiertas();
          delete estado[scopeKey];
          guardarEstadoTarjetasAbiertas(estado);
        }
      }

      function guardarSeleccion() {
        storage.setItem(STORAGE_SELECTION_KEY, JSON.stringify(seleccion));
      }

      function obtenerEstadoTarjetasAbiertas() {
        try {
          const raw = storage.getItem(STORAGE_OPEN_CARDS_KEY);
          const parsed = raw ? JSON.parse(raw) : {};
          return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
        } catch {
          return {};
        }
      }

      function guardarEstadoTarjetasAbiertas(estado) {
        storage.setItem(STORAGE_OPEN_CARDS_KEY, JSON.stringify(estado && typeof estado === 'object' ? estado : {}));
      }

      function actualizarTarjetasAbiertas(scopeKey, abiertasSet) {
        if (!scopeKey) return;
        const estado = obtenerEstadoTarjetasAbiertas();
        const lista = Array.from(abiertasSet || []).map((v) => String(v || '').trim()).filter(Boolean);
        if (lista.length) estado[scopeKey] = lista;
        else delete estado[scopeKey];
        guardarEstadoTarjetasAbiertas(estado);
      }

      function actualizarSelectorSubraza() {
        const razaSeleccionada = razaBySlug.get(String(razaSelect.value || '').trim());
        const razaId = razaSeleccionada ? Number(razaSeleccionada.id) : null;
        const opciones = Array.from(subrazaSelect.options).slice(1);
        if (!razaId) {
          opciones.forEach((opt) => {
            opt.hidden = true;
            opt.disabled = true;
          });
          subrazaControl.hidden = true;
          subrazaSelect.required = false;
          subrazaSelect.value = '';
          delete seleccion.subraza;
          return;
        }

        let visibles = 0;
        opciones.forEach((opt) => {
          const coincide = Number(opt.dataset.razaId || 0) === razaId;
          opt.hidden = !coincide;
          opt.disabled = !coincide;
          if (coincide) visibles += 1;
        });

        if (!visibles) {
          subrazaControl.hidden = true;
          subrazaSelect.required = false;
          subrazaSelect.value = '';
          delete seleccion.subraza;
          return;
        }

        subrazaControl.hidden = false;
        subrazaSelect.required = true;
        const actual = String(subrazaSelect.value || '').trim();
        const actualValida = opciones.some((opt) => !opt.hidden && opt.value === actual);
        if (!actualValida) {
          subrazaSelect.value = '';
          delete seleccion.subraza;
        }
      }

      function sincronizarSelectoresConSeleccion() {
        normalizarMulticlases();
        claseSelect.value = String(seleccion?.clase || '');
        razaSelect.value = String(seleccion?.raza || '');
        subrazaSelect.value = String(seleccion?.subraza || '');
        actualizarSelectorSubraza();
      }

      function construirMapaRasgos(...grupos) {
        const mapa = new Map();
        mapaRasgoRacialBySlug.forEach((valor, slug) => {
          if (!slug) return;
          mapa.set(slug, {
            nombre: String(valor?.nombre || '').trim(),
            descripcion: String(valor?.descripcion || '').trim()
          });
        });
        grupos.forEach((grupo) => {
          const lista = Array.isArray(grupo) ? grupo : [];
          lista.forEach((rasgo) => {
            const slug = String(rasgo?.slug || '').trim();
            if (!slug) return;
            const previo = mapa.get(slug);
            mapa.set(slug, {
              nombre: String(rasgo?.nombre || rasgo?.name || previo?.nombre || slug).trim(),
              descripcion: String(rasgo?.descripcion || previo?.descripcion || '').trim(),
              modificadores: rasgo?.modificadores ?? previo?.modificadores ?? null
            });
          });
        });
        return mapa;
      }

      const OPCIONES_ATRIBUTOS_BASE = [
        ['fuerza', 'Fuerza'],
        ['destreza', 'Destreza'],
        ['constitucion', 'Constitución'],
        ['inteligencia', 'Inteligencia'],
        ['sabiduria', 'Sabiduría'],
        ['carisma', 'Carisma']
      ];

      function normalizarAbilityPaso2(raw = '') {
        const t = String(raw || '').trim().toLowerCase();
        const sinAcentos = t.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        const map = {
          strength: 'fuerza',
          str: 'fuerza',
          fuerza: 'fuerza',
          dexterity: 'destreza',
          dex: 'destreza',
          destreza: 'destreza',
          constitution: 'constitucion',
          con: 'constitucion',
          constitucion: 'constitucion',
          inteligencia: 'inteligencia',
          intelligence: 'inteligencia',
          int: 'inteligencia',
          wisdom: 'sabiduria',
          wis: 'sabiduria',
          sabiduria: 'sabiduria',
          charisma: 'carisma',
          cha: 'carisma',
          carisma: 'carisma'
        };
        return map[sinAcentos] || '';
      }

      function calcularTotalesBaseConBonosRacialesPaso2() {
        const totals = {};
        OPCIONES_ATRIBUTOS_BASE.forEach(([slug]) => {
          totals[slug] = 0;
        });

        const slugRazaActual = String(seleccion?.raza || '').trim().toLowerCase();
        const slugSubrazaActual = String(seleccion?.subraza || '').trim().toLowerCase();
        const razaSeleccionadaActual = slugRazaActual ? razaBySlug.get(slugRazaActual) : null;
        const subrazaSeleccionadaActual = slugSubrazaActual ? subrazaBySlug.get(slugSubrazaActual) : null;

        const baseScores = obtenerBaseScoresPaso3();
        const bonusEstado = seleccion?.bonificadores_raciales_elegidos && typeof seleccion.bonificadores_raciales_elegidos === 'object'
          ? seleccion.bonificadores_raciales_elegidos
          : {};

        function agregarDesdeMods(mods, key) {
          const lista = Array.isArray(parsearJsonFlexible(mods, mods)) ? parsearJsonFlexible(mods, mods) : [];
          const elegido = Array.isArray(bonusEstado?.[key]) ? bonusEstado[key] : [];
          let idxChoice = 0;

          lista.forEach((b) => {
            if (!b || typeof b !== 'object') return;
            const idxRaw = String(b?.ability_score?.index || b?.ability_score?.name || '').trim().toLowerCase();
            const bonus = Number(b?.bonus) || 0;
            if (!bonus) return;
            if (idxRaw === 'choice') {
              const elegidoCampo = String(elegido[idxChoice] || '').trim().toLowerCase();
              idxChoice += 1;
              const field = normalizarAbilityPaso2(elegidoCampo);
              if (field) totals[field] = (totals[field] || 0) + bonus;
              return;
            }
            const field = normalizarAbilityPaso2(idxRaw);
            if (!field) return;
            totals[field] = (totals[field] || 0) + bonus;
          });
        }

        // Race bonuses (tarjeta "Bonificadores" del paso 2)
        if (razaSeleccionadaActual) {
          const filaRaza1 = Array.isArray(razaNiveles)
            ? razaNiveles.find((f) => Number(f?.RazaId) === Number(razaSeleccionadaActual.id) && Number(f?.nivel) === 1)
            : null;
          const modsRaza = obtenerBonificadoresRazaPaso2({ fila: filaRaza1, razaSeleccionada: razaSeleccionadaActual, subrazaSeleccionada: subrazaSeleccionadaActual });
          const keyRaza = `raza:${String(slugRazaActual || '')}:nivel:1`;
          if (Array.isArray(modsRaza) && modsRaza.length) agregarDesdeMods(modsRaza, keyRaza);
        }

        // Subrace bonuses (tarjeta "Subraza · Bonificadores")
        if (subrazaSeleccionadaActual) {
          const modsSubraza = parsearJsonFlexible(subrazaSeleccionadaActual?.bonuses, []);
          const keySub = `subraza:${String(slugSubrazaActual || '')}:nivel:1`;
          if (Array.isArray(modsSubraza) && modsSubraza.length) agregarDesdeMods(modsSubraza, keySub);
        }

        const totalesActuales = {};
        OPCIONES_ATRIBUTOS_BASE.forEach(([field]) => {
          const base = Number(baseScores[field]) || 8;
          const totalActual = base + (Number(totals[field]) || 0);
          totalesActuales[field] = totalActual;
        });
        return totalesActuales;
      }

      function calcularTotalesConAsiPaso2() {
        const totales = calcularTotalesBaseConBonosRacialesPaso2();
        const asiRaw = seleccion?.asi_mejoras;
        const entradas = asiRaw && typeof asiRaw === 'object'
          ? (Array.isArray(asiRaw) ? asiRaw : Object.values(asiRaw))
          : [];
        entradas.forEach((asi) => {
          if (!asi || typeof asi !== 'object') return;
          const modo = String(asi?.modo || (asi?.featSlug ? 'feat' : 'atributos')).trim().toLowerCase();
          if (modo !== 'atributos') return;
          const attrs = Array.isArray(asi?.atributos) ? asi.atributos : [];
          attrs.forEach((rawAttr) => {
            const field = normalizarAbilityPaso2(rawAttr);
            if (!field) return;
            totales[field] = (Number(totales[field]) || 0) + 1;
          });
        });
        return totales;
      }

      function esRasgoMejoraPuntuacion(rasgo) {
        const idx = String(rasgo?.index || '').trim().toLowerCase();
        return idx.includes('ability-score-improvement');
      }

      function construirAsiKey(claseSeleccionada, nivel, rasgo) {
        const slugClase = String(claseSeleccionada?.slug || claseSeleccionada?.nombre || '').trim().toLowerCase();
        const nivelNum = Number(nivel) || 1;
        const slugRasgo = String(rasgo?.index || rasgo?.slug || '').trim().toLowerCase();
        return [slugClase, nivelNum, slugRasgo].filter(Boolean).join(':');
      }

      function obtenerEstadoASI(asiKey) {
        const raw = seleccion?.asi_mejoras && typeof seleccion.asi_mejoras === 'object' ? seleccion.asi_mejoras[asiKey] : null;
        if (raw && typeof raw === 'object' && !Array.isArray(raw)) {
          const featSlug = String(raw.featSlug || '').trim().toLowerCase();
          const modoInferido = String(raw.modo || '').trim().toLowerCase() || (featSlug ? 'feat' : 'atributos');
          const atributosBase = Array.isArray(raw.atributos) ? raw.atributos : [];
          return {
            bonusMode: 'plus1plus1',
            atributos: modoInferido === 'atributos' ? atributosBase : [],
            featSlug: modoInferido === 'feat' ? featSlug : '',
            modo: modoInferido
          };
        }
        return { bonusMode: 'plus1plus1', atributos: [], featSlug: '', modo: 'atributos' };
      }

      function actualizarEstadoASI(asiKey, patch) {
        const estado = obtenerEstadoASI(asiKey);
        const p = patch || {};
        const nextModo = String((p.modo ?? estado.modo) || 'atributos').trim().toLowerCase();
        const bonusMode = 'plus1plus1';
        const nextFeatSlugRaw = p.featSlug != null ? p.featSlug : estado.featSlug;
        const nextFeatSlug = String(nextFeatSlugRaw || '').trim().toLowerCase();
        const nextAttrs = Array.isArray(p.atributos) ? p.atributos : estado.atributos;

        let nuevo = {
          ...estado,
          ...p,
          modo: nextModo,
          bonusMode
        };

        if (nextModo === 'feat') {
          nuevo.featSlug = nextFeatSlug;
          nuevo.atributos = [];
        } else {
          // atributos
          nuevo.featSlug = '';
          nuevo.atributos = Array.isArray(nextAttrs) ? nextAttrs : [];
        }

        seleccion.asi_mejoras[asiKey] = nuevo;
        return nuevo;
      }

      function recalcularFeatsDesdeASI() {
        if (!seleccion.asi_mejoras || typeof seleccion.asi_mejoras !== 'object') {
          seleccion.feats = [];
          return;
        }
        const estados = Array.isArray(seleccion.asi_mejoras) ? seleccion.asi_mejoras : Object.values(seleccion.asi_mejoras);
        const vistos = new Set();
        const feats = [];
        estados.forEach((asi) => {
          if (!asi || typeof asi !== 'object') return;
          const modo = String(asi?.modo || (asi?.featSlug ? 'feat' : 'atributos')).trim().toLowerCase();
          if (modo !== 'feat') return;
          const slug = String(asi?.featSlug || '').trim().toLowerCase();
          if (!slug || vistos.has(slug)) return;
          const feat = featBySlug.get(slug);
          if (!feat) return;
          vistos.add(slug);
          feats.push(feat);
        });
        seleccion.feats = feats;
      }

      function renderAsiSelectorHtml(asiKey, rasgo) {
        const estado = obtenerEstadoASI(asiKey);
        const modo = String(estado?.modo || (estado?.featSlug ? 'feat' : 'atributos')).trim().toLowerCase();
        const hasFeat = modo === 'feat' && Boolean(estado?.featSlug);
        const attrs = Array.isArray(estado?.atributos) ? estado.atributos : [];
        const attr0 = String(attrs?.[0] || '').trim().toLowerCase();
        const attr1 = String(attrs?.[1] || '').trim().toLowerCase();
        const totalesConAsi = modo === 'atributos' ? calcularTotalesConAsiPaso2() : null;

        const desc = String(rasgo?.descripcion || '').trim();
        const descHtml = desc
          ? `<p>${escapeHtml(desc).replace(/\\n/g, '<br/>')}</p>`
          : '';

        const disabledAttrs = modo !== 'atributos' ? 'disabled' : '';
        function puedeIncluir(slug, choiceIdx) {
          if (!totalesConAsi) return true;
          const otro = choiceIdx === 0 ? attr1 : attr0;
          const aporteActualEnCampo = (attr0 === slug ? 1 : 0) + (attr1 === slug ? 1 : 0);
          const aporteNuevoEnCampo = 1 + (otro === slug ? 1 : 0);
          const totalProyectado = Number(totalesConAsi[slug] || 0) - aporteActualEnCampo + aporteNuevoEnCampo;
          return totalProyectado <= 20;
        }

        const opcionesAttr0 = OPCIONES_ATRIBUTOS_BASE.map(([slug, nombre]) => {
          if (!puedeIncluir(slug, 0)) return '';
          return `<option value="${escapeHtml(slug)}" ${slug === attr0 ? 'selected' : ''}>${escapeHtml(nombre)}</option>`;
        }).filter(Boolean).join('');

        const opcionesAttr1 = OPCIONES_ATRIBUTOS_BASE.map(([slug, nombre]) => {
          if (!puedeIncluir(slug, 1)) return '';
          return `<option value="${escapeHtml(slug)}" ${slug === attr1 ? 'selected' : ''}>${escapeHtml(nombre)}</option>`;
        }).filter(Boolean).join('');

        const attrsHtml = `
          <div class="crear-paso2-ancestor-choice-row">
            <label class="crear-paso2-ancestor-label" for="cp2-asi-attr1-0-${escapeHtml(asiKey)}">Bonificador 1 (+1)</label>
            <select
              id="cp2-asi-attr1-0-${escapeHtml(asiKey)}"
              class="crear-paso2-panel__title-select cp2-asi-attr1-select"
              data-asi-key="${escapeHtml(asiKey)}"
              data-choice-idx="0"
              ${disabledAttrs}
            >
              <option value="">Selecciona atributo</option>
              ${opcionesAttr0}
            </select>
          </div>
          <div class="crear-paso2-ancestor-choice-row">
            <label class="crear-paso2-ancestor-label" for="cp2-asi-attr1-1-${escapeHtml(asiKey)}">Bonificador 2 (+1)</label>
            <select
              id="cp2-asi-attr1-1-${escapeHtml(asiKey)}"
              class="crear-paso2-panel__title-select cp2-asi-attr1-select"
              data-asi-key="${escapeHtml(asiKey)}"
              data-choice-idx="1"
              ${disabledAttrs}
            >
              <option value="">Selecciona atributo</option>
              ${opcionesAttr1}
            </select>
          </div>
        `;

        const opcionesFeats = featsSorted
          .map((f) => {
            const slug = String(f?.slug || '').trim().toLowerCase();
            if (!slug) return '';
            const nombre = String(f?.nombre || slug);
            const selected = slug === (estado?.featSlug || '');
            return `<option value="${escapeHtml(slug)}" ${selected ? 'selected' : ''}>${escapeHtml(nombre)}</option>`;
          })
          .join('');

        const featSelSlug = String(estado?.featSlug || '').trim().toLowerCase();
        const featSel = featSelSlug ? featBySlug.get(featSelSlug) : null;
        const featDesc = featSel?.descripcion ? String(featSel.descripcion).trim() : '';
        const featDescHtml = featDesc
          ? `<p>${escapeHtml(featDesc).replace(/\\n/g, '<br/>')}</p>`
          : `<p>Selecciona un feat para ver su descripción.</p>`;

        return `
          ${descHtml}
          <div class="cp2-asi-selector">
            <div class="crear-paso2-ancestor-choice-row">
              <label class="crear-paso2-ancestor-label" for="cp2-asi-main-mode-${escapeHtml(asiKey)}">Elección</label>
              <select
                id="cp2-asi-main-mode-${escapeHtml(asiKey)}"
                class="crear-paso2-panel__title-select cp2-asi-main-mode-select"
                data-asi-key="${escapeHtml(asiKey)}"
              >
                <option value="atributos" ${modo === 'atributos' ? 'selected' : ''}>Mejora de atributos</option>
                <option value="feat" ${modo === 'feat' ? 'selected' : ''}>Feat</option>
              </select>
            </div>

            <div class="cp2-asi-attrs-block" ${modo === 'atributos' ? '' : 'hidden'}>
              <div class="crear-paso2-ancestor-choice-row">
                <label class="crear-paso2-ancestor-label">Bonificación</label>
                <div style="font-weight:700; color:var(--dnd-red-dark); margin-top:0.2rem;">+1 y +1 (dos atributos)</div>
              </div>
              ${attrsHtml}
            </div>

            <div class="cp2-asi-feat-block" ${modo === 'feat' ? '' : 'hidden'}>
              <div class="crear-paso2-ancestor-choice-row">
                <label class="crear-paso2-ancestor-label" for="cp2-asi-feat-${escapeHtml(asiKey)}">Selecciona un feat</label>
                <select
                  id="cp2-asi-feat-${escapeHtml(asiKey)}"
                  class="crear-paso2-panel__title-select cp2-asi-feat-select"
                  data-asi-key="${escapeHtml(asiKey)}"
                >
                  <option value="">Ninguna</option>
                  ${opcionesFeats}
                </select>
              </div>
              ${featDescHtml}
            </div>
          </div>
        `;
      }

      function slugificarTexto(raw = '') {
        return String(raw || '')
          .trim()
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
      }

      function esRasgoEleccionSubclase(rasgo, claseSeleccionada, nivelRasgo, nivelDesbloqueoSubclase) {
        if (!claseSeleccionada || !nivelDesbloqueoSubclase) return false;
        if (Number(nivelRasgo) !== Number(nivelDesbloqueoSubclase)) return false;
        const opcionesSub = obtenerSubclasesDeClase(claseSeleccionada);
        if (!opcionesSub.length) return false;
        const idx = slugificarTexto(rasgo?.index || '');
        const nombre = slugificarTexto(rasgo?.name || '');
        const tiposSubclase = new Set(
          opcionesSub
            .map((s) => slugificarTexto(s?.tipo_subclase || ''))
            .filter(Boolean)
        );
        const mencionaEleccionSubclase = (txt = '') => {
          const t = String(txt || '');
          if (!t) return false;
          return t.includes('subclass') || t.includes('subclase') || t.includes('arquetipo') || t.includes('tradicion') || t.includes('tradición') || t.includes('dominio') || t.includes('senda');
        };
        if (idx && tiposSubclase.has(idx)) return true;
        if (nombre && tiposSubclase.has(nombre)) return true;
        if (mencionaEleccionSubclase(idx) || mencionaEleccionSubclase(nombre)) return true;
        return false;
      }

      function esRasgoMejoraSubclaseGenerica(rasgo, claseSeleccionada) {
        if (!claseSeleccionada) return false;
        const opcionesSub = obtenerSubclasesDeClase(claseSeleccionada);
        if (!opcionesSub.length) return false;
        const idx = slugificarTexto(rasgo?.index || '');
        const nombre = slugificarTexto(rasgo?.name || '');
        const slugsBase = new Set();
        opcionesSub.forEach((s) => {
          const tipo = slugificarTexto(s?.tipo_subclase || '');
          if (tipo) slugsBase.add(tipo);
        });
        const esMejoraPorTexto = (txt = '') => {
          const t = String(txt || '');
          if (!t) return false;
          const mencionaMejora = t.includes('improvement') || t.includes('mejora');
          if (!mencionaMejora) return false;
          const mencionaSubclase = t.includes('subclass') || t.includes('subclase') || t.includes('arquetipo') || t.includes('tradicion') || t.includes('tradición') || t.includes('dominio') || t.includes('senda');
          return mencionaSubclase;
        };
        const esMejora = (txt) => {
          if (!txt) return false;
          if (Array.from(slugsBase).some((base) => txt.startsWith(`${base}-improvement`) || txt.startsWith(`${base}-mejora`))) return true;
          return esMejoraPorTexto(txt);
        };
        return esMejora(idx) || esMejora(nombre);
      }

      function renderSelectorSubclaseHtml(claseSeleccionada, nivelClase, subclaseSeleccionadaSlug = '') {
        const opciones = obtenerSubclasesDeClase(claseSeleccionada);
        const etiquetaTipo = obtenerEtiquetaTipoSubclase(claseSeleccionada);
        const etiquetaTipoMin = etiquetaTipo.toLowerCase();
        if (!opciones.length) return '<p>Esta clase no tiene subclases disponibles.</p>';
        const nivelDesbloqueo = obtenerNivelDesbloqueoSubclase(claseSeleccionada) || 1;
        const bloqueado = Number(nivelClase) < Number(nivelDesbloqueo);
        const opts = opciones.map((sub) => {
          const slug = String(sub?.slug || '').trim();
          if (!slug) return '';
          const nombre = String(sub?.nombre || slug).trim();
          return `<option value="${escapeHtml(slug)}" ${slug === subclaseSeleccionadaSlug ? 'selected' : ''}>${escapeHtml(nombre)}</option>`;
        }).filter(Boolean).join('');
        const detalleSub = subclaseSeleccionadaSlug
          ? String(subclaseBySlug.get(subclaseSeleccionadaSlug)?.descripcion || '').trim()
          : '';
        return `
          <p>${escapeHtml(etiquetaTipo)} se elige en nivel ${nivelDesbloqueo}.</p>
          <div class="crear-paso2-ancestor-choice-row">
            <label class="crear-paso2-ancestor-label" for="cp2-subclass-select-${escapeHtml(String(claseSeleccionada?.slug || ''))}">${escapeHtml(etiquetaTipo)}</label>
            <select
              id="cp2-subclass-select-${escapeHtml(String(claseSeleccionada?.slug || ''))}"
              class="crear-paso2-panel__title-select cp2-subclass-select"
              data-clase-slug="${escapeHtml(String(claseSeleccionada?.slug || ''))}"
              ${bloqueado ? 'disabled' : ''}
            >
              <option value="">Selecciona ${escapeHtml(etiquetaTipoMin)}</option>
              ${opts}
            </select>
          </div>
          ${bloqueado ? `<p>Sube esta clase al nivel ${nivelDesbloqueo} para elegir ${escapeHtml(etiquetaTipoMin)}.</p>` : ''}
          ${detalleSub ? `<p>${escapeHtml(detalleSub).replace(/\n/g, '<br/>')}</p>` : ''}
        `;
      }

      function construirTarjetasClase(claseSeleccionada, nivelElegido, subclaseSeleccionadaSlug = '') {
        if (!claseSeleccionada) return [];
        const filas = claseNiveles
          .filter((fila) => Number(fila?.ClaseId) === Number(claseSeleccionada.id) && Number(fila?.nivel) <= nivelElegido)
          .sort((a, b) => Number(a.nivel) - Number(b.nivel));
        const tarjetaCompetencias = {
          titulo: 'Competencias de clase',
          nivel: 1,
          detalleHtml: formatearCompetenciasClase(
            claseSeleccionada.competencia,
            claseSeleccionada.tirada_salvacion,
            claseSeleccionada.slug,
            claseSeleccionada.proficiency_choices
          )
        };
        const tarjetas = [];
        let tarjetaEleccionSubclase = null;
        const etiquetaTipoSubclase = obtenerEtiquetaTipoSubclase(claseSeleccionada);
        const nivelDesbloqueoSubclase = obtenerNivelDesbloqueoSubclase(claseSeleccionada);
        const subclaseSeleccionadaValida = (() => {
          const slug = String(subclaseSeleccionadaSlug || '').trim();
          if (!slug) return false;
          const sub = subclaseBySlug.get(slug);
          return !!sub && Number(sub?.ClaseId) === Number(claseSeleccionada?.id);
        })();
        if (nivelDesbloqueoSubclase && Number(nivelElegido) >= Number(nivelDesbloqueoSubclase)) {
          tarjetaEleccionSubclase = {
            titulo: `Elección de ${String(etiquetaTipoSubclase || 'Subclase').toLowerCase()}`,
            nivel: Number(nivelDesbloqueoSubclase),
            detalleHtml: renderSelectorSubclaseHtml(claseSeleccionada, nivelElegido, subclaseSeleccionadaSlug),
            ordenInterno: 0
          };
        }

        filas.forEach((fila) => {
          const nivel = Number(fila?.nivel) || 1;
          const rasgos = Array.isArray(fila?.rasgos) ? fila.rasgos : [];

          rasgos.forEach((rasgo) => {
            if (esRasgoEleccionSubclase(rasgo, claseSeleccionada, nivel, nivelDesbloqueoSubclase)) return;
            if (subclaseSeleccionadaValida && esRasgoMejoraSubclaseGenerica(rasgo, claseSeleccionada)) return;
            const slug = String(rasgo?.index || '').trim();
            const nombre = String(rasgo?.name || slug).trim();
            if (!nombre) return;
            if (esRasgoMejoraPuntuacion(rasgo)) {
              const asiKey = construirAsiKey(claseSeleccionada, nivel, rasgo);
              tarjetas.push({
                titulo: `${nombre}`,
                nivel,
                detalleHtml: renderAsiSelectorHtml(asiKey, rasgo),
                ordenInterno: 20
              });
            } else {
              const detalle = String(rasgo?.descripcion || '').trim() || 'Sin descripción disponible.';
              tarjetas.push({
                titulo: `${nombre}`,
                nivel,
                detalle,
                ordenInterno: 20
              });
            }
          });
        });

        const subclaseSel = subclaseBySlug.get(String(subclaseSeleccionadaSlug || '').trim());
        if (subclaseSel && Number(subclaseSel?.ClaseId) === Number(claseSeleccionada?.id)) {
          const filasSub = (Array.isArray(subclaseNiveles) ? subclaseNiveles : [])
            .filter((fila) => Number(fila?.SubclaseId) === Number(subclaseSel?.id) && Number(fila?.nivel) <= Number(nivelElegido))
            .sort((a, b) => Number(a?.nivel) - Number(b?.nivel));
          filasSub.forEach((filaSub) => {
            const nivelSub = Number(filaSub?.nivel) || 1;
            const rasgosSub = Array.isArray(filaSub?.rasgos) ? filaSub.rasgos : [];
            rasgosSub.forEach((rasgo) => {
              const nombre = String(rasgo?.name || rasgo?.index || '').trim();
              if (!nombre) return;
              const detalle = String(rasgo?.descripcion || '').trim() || 'Sin descripción disponible.';
              tarjetas.push({
                titulo: `${etiquetaTipoSubclase} · ${nombre}`,
                nivel: nivelSub,
                detalle,
                ordenInterno: 30
              });
            });
          });
        }

        const tarjetasOrdenadas = tarjetas
          .slice()
          .sort((a, b) => {
            const nivelA = Number(a?.nivel) || 1;
            const nivelB = Number(b?.nivel) || 1;
            if (nivelA !== nivelB) return nivelA - nivelB;
            const ordenA = Number(a?.ordenInterno) || 99;
            const ordenB = Number(b?.ordenInterno) || 99;
            if (ordenA !== ordenB) return ordenA - ordenB;
            return String(a?.titulo || '').localeCompare(String(b?.titulo || ''), 'es');
          })
          .map(({ ordenInterno, ...tarjeta }) => tarjeta);

        return [tarjetaCompetencias, ...(tarjetaEleccionSubclase ? [tarjetaEleccionSubclase] : []), ...tarjetasOrdenadas];
      }

      function construirTarjetasRaza(razaSeleccionada, subrazaSeleccionada, nivelElegido) {
        if (!razaSeleccionada) return [];
        const slugRaza = String(razaSeleccionada?.slug || '').trim().toLowerCase();
        const mapaRasgos = construirMapaRasgos(
          razaSeleccionada.rasgosDetalle,
          subrazaSeleccionada?.rasgosDetalle
        );

        const filas = razaNiveles
          .filter((fila) => Number(fila?.RazaId) === Number(razaSeleccionada.id) && Number(fila?.nivel) <= nivelElegido)
          .sort((a, b) => Number(a.nivel) - Number(b.nivel));

        const tarjetas = [];
        const filasFuente = filas.length
          ? filas
          : [{
              nivel: 1,
              rasgos: parsearJsonFlexible(razaSeleccionada?.traits, []),
              modificadores: parsearJsonFlexible(razaSeleccionada?.bonuses, []),
              velocidad: razaSeleccionada?.velocidad,
              idiomas: parsearJsonFlexible(razaSeleccionada?.idiomas, [])
            }];

        filasFuente.forEach((fila) => {
          const nivel = Number(fila?.nivel) || 1;
          if (nivel === 1) {
            const idiomasCfg = normalizarIdiomasRacialesConfig(fila?.idiomas || razaSeleccionada?.idiomas, slugRaza);
            tarjetas.push({
              titulo: 'Idiomas',
              nivel,
              ...(idiomasCfg.choose > 0
                ? {
                    detalleHtml: renderSelectorIdiomaRacial({
                      key: `raza:${slugRaza}:idiomas:nivel:${nivel}`,
                      opciones: idiomasCfg.options,
                      cantidad: idiomasCfg.choose,
                      descripcion: `Fijos: ${formatearIdiomas(idiomasCfg.fixed)}`
                    })
                  }
                : { detalle: formatearIdiomas(idiomasCfg.fixed) })
            });

            const velocidad = Number(fila?.velocidad) || Number(razaSeleccionada?.velocidad) || 0;
            if (velocidad > 0) {
              tarjetas.push({
                titulo: 'Velocidad',
                nivel,
                detalle: `${velocidad} pies`
              });
            }

            const bonosBase = obtenerBonificadoresRazaPaso2({ fila, razaSeleccionada, subrazaSeleccionada });
            const analisis = analizarBonificadoresRaciales(bonosBase);
            if (Array.isArray(bonosBase) && bonosBase.length) {
              const detalleBase = analisis.fijos.length
                ? analisis.fijos.join(', ')
                : (analisis.elecciones.length ? 'Bonificadores a elección.' : formatearBonificadores(bonosBase));
              tarjetas.push({
                titulo: 'Bonificadores',
                nivel,
                ...(analisis.elecciones.length
                  ? {
                      detalleHtml: renderSelectorBonificadorRacial({
                        key: `raza:${slugRaza}:nivel:${nivel}`,
                        elecciones: analisis.elecciones,
                        descripcion: detalleBase
                      })
                    }
                  : { detalle: detalleBase })
              });
            }
          }

          const rasgos = Array.isArray(parsearJsonFlexible(fila?.rasgos, [])) ? parsearJsonFlexible(fila?.rasgos, []) : [];
          rasgos.forEach((ref) => {
            const slug = String(ref?.index || '').trim();
            const nombreApi = String(ref?.name || '').trim();
            const local = slug ? mapaRasgos.get(slug) : null;
            const titulo = (local?.nombre || nombreApi || slug || 'Rasgo racial').trim();
            const detalle = String(local?.descripcion || '').trim() || 'Sin descripción disponible.';
            const esAscendenciaDraconica = slug === 'draconic-ancestry';
            const esArmaAliento = slug === 'breath-weapon';
            const esResistencia = slug === 'damage-resistance';
            const eleccionComp = extraerOpcionesCompetenciaRacial(local?.modificadores, slug);
            if (esAscendenciaDraconica) {
              tarjetas.push({ titulo, nivel, detalleHtml: renderTablaAncestrosDraconidos() });
            } else if (esArmaAliento) {
              const ancestro = getAncestroDraconidoActual();
              if (!ancestro) {
                tarjetas.push({
                  titulo,
                  nivel: nivelEscaladoArmaAliento(nivelElegido),
                  detalle: 'Selecciona una ascendencia dracónica para ver el tipo de daño y el arma de aliento.'
                });
                return;
              }
              tarjetas.push({
                titulo,
                nivel: nivelEscaladoArmaAliento(nivelElegido),
                detalle: `Ascendencia elegida: ${ancestro.nombre}\nArma de aliento: ${ancestro.aliento}\nDaño actual: ${danoArmaAlientoPorNivel(nivelElegido)} (${ancestro.dano})\n\nProgresión de daño:\n${resumenMejorasArmaAlientoPorNivel(nivelElegido)}`
              });
            } else if (esResistencia) {
              const ancestro = getAncestroDraconidoActual();
              if (!ancestro) {
                tarjetas.push({
                  titulo,
                  nivel,
                  detalle: 'Selecciona una ascendencia dracónica para activar la resistencia elemental.'
                });
                return;
              }
              tarjetas.push({
                titulo,
                nivel,
                detalle: `Ascendencia elegida: ${ancestro.nombre}\nResistencia activa: ${ancestro.dano}`
              });
            } else if (eleccionComp.opciones.length && eleccionComp.cantidad > 0) {
              tarjetas.push({
                titulo,
                nivel,
                detalleHtml: renderSelectorCompetenciaRacial({
                  rasgoSlug: slug || titulo.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
                  opciones: eleccionComp.opciones,
                  cantidad: eleccionComp.cantidad,
                  descripcion: detalle
                })
              });
            } else {
              tarjetas.push({ titulo, nivel, detalle });
            }
          });
        });

        if (subrazaSeleccionada) {
          const bonosSubraza = parsearJsonFlexible(subrazaSeleccionada?.bonuses, []);
          if (Array.isArray(bonosSubraza) && bonosSubraza.length) {
            const analisisSubraza = analizarBonificadoresRaciales(bonosSubraza);
            const detalleSubraza = analisisSubraza.fijos.length
              ? analisisSubraza.fijos.join(', ')
              : (analisisSubraza.elecciones.length
                ? descripcionEleccionesBonificador(analisisSubraza.elecciones)
                : formatearBonificadores(bonosSubraza));
            tarjetas.push({
              titulo: 'Subraza · Bonificadores',
              nivel: 1,
              ...(analisisSubraza.elecciones.length
                ? {
                    detalleHtml: renderSelectorBonificadorRacial({
                      key: `subraza:${String(subrazaSeleccionada?.slug || '').trim().toLowerCase()}:nivel:1`,
                      elecciones: analisisSubraza.elecciones,
                      descripcion: detalleSubraza
                    })
                  }
                : { detalle: detalleSubraza })
            });
          }

          const rasgosSubraza = Array.isArray(subrazaSeleccionada?.rasgosDetalle)
            ? subrazaSeleccionada.rasgosDetalle
            : [];
          rasgosSubraza.forEach((rasgo) => {
            const slug = String(rasgo?.slug || '').trim();
            const local = slug ? mapaRasgos.get(slug) : null;
            const titulo = String(local?.nombre || rasgo?.nombre || rasgo?.name || slug || 'Rasgo de subraza').trim();
            const detalle = String(local?.descripcion || rasgo?.descripcion || '').trim() || 'Sin descripción disponible.';
            tarjetas.push({
              titulo: `Subraza · ${titulo}`,
              nivel: 1,
              detalle
            });
          });
        }

        return tarjetas;
      }

      function renderTarjetas(container, tarjetas, mensajeVacio, scopeKey = '') {
        const estadoAbiertas = obtenerEstadoTarjetasAbiertas();
        const abiertas = new Set(Array.isArray(estadoAbiertas[scopeKey]) ? estadoAbiertas[scopeKey] : []);
        container.dataset.openScope = String(scopeKey || '');
        container.innerHTML = '';
        if (!Array.isArray(tarjetas) || !tarjetas.length) {
          const empty = document.createElement('p');
          empty.className = 'crear-paso2-empty';
          empty.textContent = mensajeVacio;
          container.appendChild(empty);
          return;
        }

        tarjetas.forEach((tarjeta, idx) => {
          const card = document.createElement('article');
          card.className = 'crear-paso2-card';
          card.setAttribute('aria-expanded', 'false');

          const toggle = document.createElement('button');
          toggle.type = 'button';
          toggle.className = 'crear-paso2-drawer__toggle';
          toggle.setAttribute('aria-expanded', 'false');

          const title = document.createElement('span');
          title.className = 'crear-paso2-card__title';
          title.textContent = `Nivel ${tarjeta.nivel} · ${tarjeta.titulo}`;
          toggle.appendChild(title);

          const detail = document.createElement('div');
          detail.className = 'crear-paso2-card__detail';
          detail.hidden = true;
          if (typeof tarjeta.detalleHtml === 'string' && tarjeta.detalleHtml.trim()) {
            detail.classList.add('is-html');
            detail.innerHTML = tarjeta.detalleHtml;
          } else {
            detail.textContent = String(tarjeta.detalle || '');
          }

          card.appendChild(toggle);
          card.appendChild(detail);

          toggle.addEventListener('click', () => {
            const expanded = card.getAttribute('aria-expanded') === 'true';
            card.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            card.classList.toggle('is-open', !expanded);
            detail.hidden = expanded;
            const keyTitulo = String(title.textContent || '').trim();
            if (keyTitulo) {
              if (!expanded) abiertas.add(keyTitulo);
              else abiertas.delete(keyTitulo);
              actualizarTarjetasAbiertas(scopeKey, abiertas);
            }
          });

          function actualizarAvisoPendiente() {
            const selectors = [
              // Raza (ya existente)
              '.cp2-race-choice-select',
              '.cp2-class-choice-select',
              '#cp2-draconic-ancestor-select',
              '.cp2-subclass-select',
              // ASI (atributos / feat)
              '.cp2-asi-attr1-select',
              '.cp2-asi-feat-select',
              '.cp2-asi-main-mode-select'
            ].join(', ');
            const selectsPendientes = Array.from(detail.querySelectorAll(selectors));
            const tienePendiente = selectsPendientes.some((sel) => {
              if (sel.disabled) return false;
              // Ignora únicamente los selects que están dentro de bloques internos ASI ocultos
              // (no el `detail` completo de la tarjeta, que también usa `hidden` cuando está colapsada).
              if (sel.closest('.cp2-asi-attrs-block[hidden], .cp2-asi-feat-block[hidden]')) return false;
              return !String(sel.value || '').trim();
            });
            card.classList.toggle('is-pending', tienePendiente);
            let badge = title.querySelector('.crear-paso2-card__pending');
            if (tienePendiente && !badge) {
              badge = document.createElement('span');
              badge.className = 'crear-paso2-card__pending';
              badge.textContent = ' !';
              title.appendChild(badge);
            } else if (!tienePendiente && badge) {
              badge.remove();
            }
          }

          card.dataset.cardIndex = String(idx);
          container.appendChild(card);

          const ancestroSelect = detail.querySelector('#cp2-draconic-ancestor-select');
          if (ancestroSelect) {
            ancestroSelect.addEventListener('click', (event) => event.stopPropagation());
            ancestroSelect.addEventListener('change', (event) => {
              ancestroDraconido = String(event.target?.value || '').trim().toLowerCase();
              if (ancestroDraconido) {
                storage.setItem(STORAGE_DRACONIC_ANCESTRY_KEY, ancestroDraconido);
                seleccion.ascendencia_draconida = ancestroDraconido;
              } else {
                storage.removeItem(STORAGE_DRACONIC_ANCESTRY_KEY);
                delete seleccion.ascendencia_draconida;
              }
              guardarSeleccion();
              render();
            });
          }

          const subclassSelects = Array.from(detail.querySelectorAll('.cp2-subclass-select'));
          subclassSelects.forEach((selectEl) => {
            selectEl.addEventListener('click', (event) => event.stopPropagation());
            selectEl.addEventListener('change', () => {
              const claseSlug = String(selectEl.dataset.claseSlug || '').trim();
              if (!claseSlug) return;
              actualizarSubclaseClase(claseSlug, String(selectEl.value || '').trim());
              guardarSeleccion();
              render();
            });
          });

          const classChoiceSelects = Array.from(detail.querySelectorAll('.cp2-class-choice-select'));
          classChoiceSelects.forEach((selectEl) => {
            selectEl.addEventListener('click', (event) => event.stopPropagation());
            selectEl.addEventListener('change', () => {
              const key = String(selectEl.dataset.classChoiceKey || '').trim();
              const idxChoice = Math.max(0, Number(selectEl.dataset.choiceIdx) || 0);
              if (!key) return;
              const estado = obtenerEstadoCompetenciasClase();
              const prev = Array.isArray(estado[key]) ? estado[key] : [];
              const valorNuevo = String(selectEl.value || '').trim();
              if (valorNuevo) {
                for (let i = 0; i < prev.length; i += 1) {
                  if (i === idxChoice) continue;
                  if (String(prev[i] || '').trim() === valorNuevo) prev[i] = '';
                }
              }
              prev[idxChoice] = valorNuevo;
              estado[key] = prev;
              seleccion.competencias_clase_elegidas = estado;
              guardarSeleccion();
              render();
            });
          });

          const selectsCompetencia = Array.from(detail.querySelectorAll('.cp2-race-choice-select'));
          selectsCompetencia.forEach((selectEl) => {
            selectEl.addEventListener('click', (event) => event.stopPropagation());
            selectEl.addEventListener('change', () => {
              const raceLanguageKey = String(selectEl.dataset.raceLanguageChoiceKey || '').trim();
              const bonusKey = String(selectEl.dataset.bonusKey || '').trim();
              const rasgo = String(selectEl.dataset.rasgo || '').trim();
              const idxChoice = Math.max(0, Number(selectEl.dataset.choiceIdx) || 0);
              if (raceLanguageKey) {
                const estadoIdiomas = obtenerEstadoIdiomasRaciales();
                const valorNuevo = normalizarIdiomaSlug(selectEl.value || '');
                if (valorNuevo) {
                  for (let i = 0; i < estadoIdiomas.length; i += 1) {
                    if (i === idxChoice) continue;
                    if (normalizarIdiomaSlug(estadoIdiomas[i]) === valorNuevo) estadoIdiomas[i] = '';
                  }
                }
                estadoIdiomas[idxChoice] = valorNuevo;
                seleccion.idiomas_raciales_elegidos = estadoIdiomas;
                guardarSeleccion();
                render();
                return;
              }
              if (!rasgo && !bonusKey) return;
              if (bonusKey) {
                const estadoBonos = obtenerEstadoBonificadoresRaciales();
                const prevBonos = Array.isArray(estadoBonos[bonusKey]) ? estadoBonos[bonusKey] : [];
                const valorNuevo = String(selectEl.value || '').trim();
                if (valorNuevo) {
                  for (let i = 0; i < prevBonos.length; i += 1) {
                    if (i === idxChoice) continue;
                    if (String(prevBonos[i] || '').trim() === valorNuevo) {
                      prevBonos[i] = '';
                    }
                  }
                }
                prevBonos[idxChoice] = valorNuevo;
                estadoBonos[bonusKey] = prevBonos;
                seleccion.bonificadores_raciales_elegidos = estadoBonos;
                render();
                return;
              } else {
                const estado = obtenerEstadoCompetenciasRaciales();
                const prev = Array.isArray(estado[rasgo]) ? estado[rasgo] : [];
                prev[idxChoice] = String(selectEl.value || '').trim();
                estado[rasgo] = prev;
                seleccion.competencias_raciales_elegidas = estado;
              }
              guardarSeleccion();
              actualizarAvisoPendiente();
            });
          });

          // ASI: selección de mejora de atributos y/o dote (feats)
          const asiMainModeSelects = Array.from(detail.querySelectorAll('.cp2-asi-main-mode-select'));
          asiMainModeSelects.forEach((selectEl) => {
            selectEl.addEventListener('click', (event) => event.stopPropagation());
            selectEl.addEventListener('change', () => {
              const asiKey = String(selectEl.dataset.asiKey || '').trim();
              if (!asiKey) return;
              const modoNuevo = String(selectEl.value || '').trim().toLowerCase();
              const estado = obtenerEstadoASI(asiKey);

              if (modoNuevo === 'feat') {
                actualizarEstadoASI(asiKey, { modo: 'feat', featSlug: estado?.featSlug || '' });
              } else {
                actualizarEstadoASI(asiKey, { modo: 'atributos' });
              }

              recalcularFeatsDesdeASI();
              guardarSeleccion();
              render();
            });
          });

          const asiFeatSelects = Array.from(detail.querySelectorAll('.cp2-asi-feat-select'));
          asiFeatSelects.forEach((selectEl) => {
            selectEl.addEventListener('click', (event) => event.stopPropagation());
            selectEl.addEventListener('change', () => {
              const asiKey = String(selectEl.dataset.asiKey || '').trim();
              if (!asiKey) return;
              const slugFeat = String(selectEl.value || '').trim().toLowerCase();
              actualizarEstadoASI(asiKey, { modo: 'feat', featSlug: slugFeat });
              recalcularFeatsDesdeASI();
              guardarSeleccion();
              render();
            });
          });

          const asiAttr1Selects = Array.from(detail.querySelectorAll('.cp2-asi-attr1-select'));
          asiAttr1Selects.forEach((selectEl) => {
            selectEl.addEventListener('click', (event) => event.stopPropagation());
            selectEl.addEventListener('change', () => {
              const asiKey = String(selectEl.dataset.asiKey || '').trim();
              if (!asiKey) return;
              const selects = Array.from(detail.querySelectorAll('.cp2-asi-attr1-select'));
              const v0 = (selects.find((s) => String(s.dataset.choiceIdx) === '0')?.value || '').trim().toLowerCase();
              const v1 = (selects.find((s) => String(s.dataset.choiceIdx) === '1')?.value || '').trim().toLowerCase();
              const attrs = [];
              if (v0) attrs.push(v0);
              if (v1) attrs.push(v1);
              actualizarEstadoASI(asiKey, { modo: 'atributos', atributos: attrs });
              guardarSeleccion();
              render();
            });
          });

          actualizarAvisoPendiente();

          const keyTitulo = String(title.textContent || '').trim();
          if (abiertas.has(keyTitulo)) {
            card.setAttribute('aria-expanded', 'true');
            toggle.setAttribute('aria-expanded', 'true');
            card.classList.add('is-open');
            detail.hidden = false;
          }
        });
      }

      function renderSeccionesClase() {
        claseCardsEl.innerHTML = '';
        const clasesActuales = obtenerMulticlases();
        if (!clasesActuales.length) {
          renderTarjetas(claseCardsEl, [], 'Primero selecciona una clase en el paso 1.', 'clase:empty');
          return;
        }

        clasesActuales.forEach((filaClase) => {
          const clase = claseBySlug.get(filaClase.slug);
          if (!clase) return;
          const nivelClase = Math.max(1, Number(filaClase.nivel) || 1);
          const section = document.createElement('section');
          section.className = 'crear-paso2-class-section';
          section.dataset.slug = String(filaClase.slug || '');

          const head = document.createElement('div');
          head.className = 'crear-paso2-class-section__head';
          head.innerHTML = `
            <p class="crear-paso2-class-section__title">${String(clase.nombre || filaClase.slug)} · nivel ${nivelClase}</p>
          `;
          const toggleBtn = document.createElement('button');
          toggleBtn.type = 'button';
          toggleBtn.className = 'btn btn-secondary crear-paso2-class-section__toggle';
          const colapsada = collapsedClassBySlug.has(filaClase.slug);
          toggleBtn.textContent = colapsada ? 'Mostrar características' : 'Contraer características';
          toggleBtn.setAttribute('aria-pressed', colapsada ? 'true' : 'false');
          head.appendChild(toggleBtn);
          section.appendChild(head);

          const cardsWrap = document.createElement('div');
          cardsWrap.className = 'crear-paso2-card-list';
          if (colapsada) cardsWrap.setAttribute('hidden', '');
          section.appendChild(cardsWrap);

          const subclaseSeleccionada = String(filaClase?.subclase || '').trim();
          const cards = construirTarjetasClase(clase, nivelClase, subclaseSeleccionada);
          renderTarjetas(cardsWrap, cards, 'No hay datos de clase para ese nivel.', `clase:${filaClase.slug}`);
          const actualizarAvisoBotonSeccion = () => {
            const pendientes = cardsWrap.querySelectorAll('.crear-paso2-card.is-pending').length > 0;
            toggleBtn.classList.toggle('is-pending', pendientes);
            let badge = toggleBtn.querySelector('.crear-paso2-class-section__pending');
            if (pendientes && !badge) {
              badge = document.createElement('span');
              badge.className = 'crear-paso2-class-section__pending';
              badge.textContent = ' !';
              toggleBtn.appendChild(badge);
            } else if (!pendientes && badge) {
              badge.remove();
            }
          };
          actualizarAvisoBotonSeccion();

          toggleBtn.addEventListener('click', () => {
            const estaColapsada = cardsWrap.hasAttribute('hidden');
            if (estaColapsada) {
              cardsWrap.removeAttribute('hidden');
              collapsedClassBySlug.delete(filaClase.slug);
              toggleBtn.textContent = 'Contraer características';
              toggleBtn.setAttribute('aria-pressed', 'false');
            } else {
              contraerTarjetasDentro(cardsWrap);
              cardsWrap.setAttribute('hidden', '');
              collapsedClassBySlug.add(filaClase.slug);
              toggleBtn.textContent = 'Mostrar características';
              toggleBtn.setAttribute('aria-pressed', 'true');
            }
            actualizarAvisoBotonSeccion();
          });

          claseCardsEl.appendChild(section);
        });
      }

      function render() {
        normalizarMulticlases();
        const claseSlug = String(seleccion?.clase || claseSelect.value || '').trim();
        const razaSlug = String(razaSelect.value || '').trim();
        if (claseSlug) seleccion.clase = claseSlug;
        else delete seleccion.clase;
        if (razaSlug) seleccion.raza = razaSlug;
        else delete seleccion.raza;
        actualizarSelectorSubraza();
        const subrazaSlug = String(subrazaSelect.value || '').trim();
        if (subrazaSlug) seleccion.subraza = subrazaSlug;
        else delete seleccion.subraza;

        const razaSeleccionada = razaBySlug.get(razaSlug);
        const subrazaSeleccionada = subrazaBySlug.get(subrazaSlug);
        const claseSeleccionada = claseBySlug.get(claseSlug);
        const nivelElegido = Math.max(1, nivelTotalPersonaje());
        seleccion.multiclases = obtenerMulticlases().map((filaClase) => {
          const clase = claseBySlug.get(String(filaClase?.slug || '').trim());
          if (!clase) return filaClase;
          const nivelClase = Number(filaClase?.nivel) || 1;
          const nivelDesbloqueo = obtenerNivelDesbloqueoSubclase(clase);
          const subclaseSlug = String(filaClase?.subclase || '').trim();
          const sub = subclaseBySlug.get(subclaseSlug);
          const valida = sub && Number(sub?.ClaseId) === Number(clase?.id);
          if (!nivelDesbloqueo || nivelClase < nivelDesbloqueo) {
            return { ...filaClase, subclase: '' };
          }
          return { ...filaClase, subclase: valida ? subclaseSlug : '' };
        });
        // Rasgos activos (clase + subclase) hasta el nivel elegido: base para aplicar modificadores en paso 3.
        const rasgosActivosClase = [];
        const vistosRasgoActivo = new Set();
        const filasActivas = obtenerMulticlases();
        filasActivas.forEach((filaClase) => {
          const slugClase = String(filaClase?.slug || '').trim();
          if (!slugClase) return;
          const clase = claseBySlug.get(slugClase);
          if (!clase) return;
          const maxNivelClase = Number(filaClase?.nivel) || 1;
          const filasClase = (Array.isArray(claseNiveles) ? claseNiveles : [])
            .filter((f) => Number(f?.ClaseId) === Number(clase.id) && Number(f?.nivel) <= maxNivelClase)
            .sort((a, b) => Number(a?.nivel) - Number(b?.nivel));
          filasClase.forEach((filaNivel) => {
            const nivelRasgo = Number(filaNivel?.nivel) || 1;
            const rasgos = Array.isArray(filaNivel?.rasgos) ? filaNivel.rasgos : [];
            rasgos.forEach((rasgo) => {
              const slugRasgo = String(rasgo?.index || rasgo?.slug || '').trim();
              const nombreRasgo = String(rasgo?.name || rasgo?.nombre || slugRasgo).trim();
              const key = `clase:${slugClase}:${nivelRasgo}:${slugRasgo || nombreRasgo}`;
              if (!nombreRasgo || vistosRasgoActivo.has(key)) return;
              vistosRasgoActivo.add(key);
              rasgosActivosClase.push({
                source: 'clase',
                claseSlug: slugClase,
                nivel: nivelRasgo,
                slug: slugRasgo,
                nombre: nombreRasgo,
                descripcion: String(rasgo?.descripcion || '').trim(),
                modificadores: rasgo?.modificadores ?? null
              });
            });
          });

          const subclaseSlugActiva = String(filaClase?.subclase || '').trim();
          const subclaseActiva = subclaseBySlug.get(subclaseSlugActiva);
          if (!subclaseActiva || Number(subclaseActiva?.ClaseId) !== Number(clase.id)) return;
          const filasSub = (Array.isArray(subclaseNiveles) ? subclaseNiveles : [])
            .filter((f) => Number(f?.SubclaseId) === Number(subclaseActiva.id) && Number(f?.nivel) <= maxNivelClase)
            .sort((a, b) => Number(a?.nivel) - Number(b?.nivel));
          filasSub.forEach((filaNivelSub) => {
            const nivelRasgo = Number(filaNivelSub?.nivel) || 1;
            const rasgosSub = Array.isArray(filaNivelSub?.rasgos) ? filaNivelSub.rasgos : [];
            rasgosSub.forEach((rasgo) => {
              const slugRasgo = String(rasgo?.index || rasgo?.slug || '').trim();
              const nombreRasgo = String(rasgo?.name || rasgo?.nombre || slugRasgo).trim();
              const key = `subclase:${subclaseSlugActiva}:${nivelRasgo}:${slugRasgo || nombreRasgo}`;
              if (!nombreRasgo || vistosRasgoActivo.has(key)) return;
              vistosRasgoActivo.add(key);
              rasgosActivosClase.push({
                source: 'subclase',
                claseSlug: slugClase,
                subclaseSlug: subclaseSlugActiva,
                nivel: nivelRasgo,
                slug: slugRasgo,
                nombre: nombreRasgo,
                descripcion: String(rasgo?.descripcion || '').trim(),
                modificadores: rasgo?.modificadores ?? null
              });
            });
          });
        });
        seleccion.rasgos_activos_clase = rasgosActivosClase;
        // Mantén la selección de mejoras (ASI) coherente cuando cambie la clase / multiclase.
        if (seleccion.asi_mejoras && typeof seleccion.asi_mejoras === 'object') {
          const asiKeysActivos = new Set();
          obtenerMulticlases().forEach((filaClase) => {
            const clase = claseBySlug.get(String(filaClase?.slug || '').trim());
            if (!clase) return;
            const maxNivelClase = Number(filaClase?.nivel) || 1;
            const filasClase = (Array.isArray(claseNiveles) ? claseNiveles : [])
              .filter((f) => Number(f?.ClaseId) === Number(clase.id) && Number(f?.nivel) <= maxNivelClase);
            filasClase.forEach((fila) => {
              const nivelFila = Number(fila?.nivel) || 1;
              const rasgos = Array.isArray(fila?.rasgos) ? fila.rasgos : [];
              rasgos.forEach((rasgo) => {
                if (!esRasgoMejoraPuntuacion(rasgo)) return;
                const asiKey = construirAsiKey(clase, nivelFila, rasgo);
                if (asiKey) asiKeysActivos.add(asiKey);
              });
            });
          });
          seleccion.asi_mejoras = Object.fromEntries(
            Object.entries(seleccion.asi_mejoras).filter(([k]) => asiKeysActivos.has(k))
          );
          recalcularFeatsDesdeASI();
        }
        const tieneAscendenciaDraconica = (() => {
          const filaRaza1 = Array.isArray(razaNiveles)
            ? razaNiveles.find((f) => Number(f?.RazaId) === Number(razaSeleccionada?.id) && Number(f?.nivel) === 1)
            : null;
          const rasgosNivel1 = Array.isArray(parsearJsonFlexible(filaRaza1?.rasgos, []))
            ? parsearJsonFlexible(filaRaza1?.rasgos, [])
            : [];
          return rasgosNivel1.some((r) => String(r?.index || r?.name || '').trim().toLowerCase() === 'draconic-ancestry');
        })();
        if (tieneAscendenciaDraconica && ancestroDraconido) seleccion.ascendencia_draconida = ancestroDraconido;
        else delete seleccion.ascendencia_draconida;
        if (!seleccion.competencias_raciales_elegidas || typeof seleccion.competencias_raciales_elegidas !== 'object') {
          seleccion.competencias_raciales_elegidas = {};
        }
        if (!seleccion.competencias_clase_elegidas || typeof seleccion.competencias_clase_elegidas !== 'object') {
          seleccion.competencias_clase_elegidas = {};
        }
        if (!seleccion.bonificadores_raciales_elegidos || typeof seleccion.bonificadores_raciales_elegidos !== 'object') {
          seleccion.bonificadores_raciales_elegidos = {};
        }

        // Snapshot estable para paso 4: evita pérdidas por variaciones
        // de formato al reconstruir habilidades/salvaciones.
        (function actualizarResumenCompetenciasPaso2() {
          const resumen = {
            clase: String(claseSlug || '').trim(),
            salvaciones: [],
            habilidades: []
          };
          const habilidadesSet = new Set();
          const salvacionesSet = new Set();
          function normalizarSkillSlug(raw = '') {
            return String(raw || '')
              .trim()
              .toLowerCase()
              .replace(/^skills?[-_:]*/, '')
              .replace(/\s+/g, '-')
              .replace(/[^a-z0-9-]+/g, '-')
              .replace(/-+/g, '-')
              .replace(/^-+|-+$/g, '');
          }
          function pushSkill(raw) {
            const slug = normalizarSkillSlug(raw);
            if (slug) habilidadesSet.add(slug);
          }
          function pushSalvacion(raw) {
            const txt = String(raw || '').trim().toLowerCase();
            if (!txt) return;
            if (txt.includes('str') || txt.includes('strength') || txt.includes('fuerza')) salvacionesSet.add('fuerza');
            else if (txt.includes('dex') || txt.includes('dexterity') || txt.includes('destreza')) salvacionesSet.add('destreza');
            else if (txt.includes('con') || txt.includes('constitution') || txt.includes('constitucion')) salvacionesSet.add('constitucion');
            else if (txt.includes('int') || txt.includes('intelligence') || txt.includes('inteligencia')) salvacionesSet.add('inteligencia');
            else if (txt.includes('wis') || txt.includes('wisdom') || txt.includes('sabiduria')) salvacionesSet.add('sabiduria');
            else if (txt.includes('cha') || txt.includes('charisma') || txt.includes('carisma')) salvacionesSet.add('carisma');
          }
          const salvacionesClase = Array.isArray(claseSeleccionada?.tirada_salvacion) ? claseSeleccionada.tirada_salvacion : [];
          salvacionesClase.forEach((item) => {
            pushSalvacion(String(item?.index || item?.name || item || ''));
          });
          const compClase = parsearJsonFlexible(claseSeleccionada?.competencia, {});
          const profsClase = Array.isArray(compClase?.proficiencies) ? compClase.proficiencies : [];
          profsClase.forEach((p) => {
            const tipo = String(p?.tipo || '').trim().toLowerCase();
            const ref = String(p?.index || p?.slug || p?.name || '').trim();
            if (tipo === 'habilidad' || tipo === 'skill' || tipo === 'skills' || ref.toLowerCase().includes('skill')) {
              pushSkill(ref);
            }
          });
          const elegidasClase = seleccion?.competencias_clase_elegidas && typeof seleccion.competencias_clase_elegidas === 'object'
            ? Object.values(seleccion.competencias_clase_elegidas)
            : [];
          const elegidasRaza = seleccion?.competencias_raciales_elegidas && typeof seleccion.competencias_raciales_elegidas === 'object'
            ? Object.values(seleccion.competencias_raciales_elegidas)
            : [];
          [...elegidasClase, ...elegidasRaza].forEach((v) => {
            const lista = Array.isArray(v) ? v : [v];
            lista.forEach((item) => {
              const raw = String(item || '').trim();
              if (!raw) return;
              if (raw.toLowerCase().includes('saving throw') || raw.toLowerCase().includes('salvacion') || raw.toLowerCase().includes('salvación')) {
                pushSalvacion(raw);
              } else {
                pushSkill(raw);
              }
            });
          });
          resumen.salvaciones = Array.from(salvacionesSet);
          resumen.habilidades = Array.from(habilidadesSet);
          seleccion.resumen_competencias_paso2 = resumen;
        })();

        if (subrazaSeleccionada && razaSeleccionada && Number(subrazaSeleccionada.RazaId) !== Number(razaSeleccionada.id)) {
          delete seleccion.subraza;
          subrazaSelect.value = '';
        }
        preguardarIdiomasConocidos(razaSeleccionada, subrazaSeleccionada);
        guardarSeleccion();
        claseSelect.value = claseSlug;
        renderResumenClase();
        renderListaMulticlase();
        renderClassPicker();

        if (!razaSeleccionada) {
          renderTarjetas(
            claseCardsEl,
            [],
            'Primero selecciona una clase y una raza en el paso 1.',
            'clase:empty'
          );
          renderTarjetas(
            razaCardsEl,
            [],
            'Primero selecciona una clase y una raza en el paso 1.',
            'raza:empty'
          );
          return;
        }

        renderSeccionesClase();
        const tarjetasRaza = construirTarjetasRaza(razaSeleccionada, subrazaSeleccionada, nivelElegido);
        renderTarjetas(
          razaCardsEl,
          tarjetasRaza,
          'No hay datos de raza para ese nivel.',
          `raza:${razaSlug || 'none'}:${subrazaSlug || 'none'}`
        );
      }

      sincronizarSelectoresConSeleccion();
      inicializarDropdownCatalogo({
        selectEl: razaSelect,
        triggerEl: razaTrigger,
        menuEl: razaMenu,
        mapBySlug: razaBySlug,
        lista: razas,
        placeholder: 'Selecciona raza'
      });
      renderClassPicker();

      claseSelect.addEventListener('change', () => {
        render();
      });

      razaSelect.addEventListener('change', () => {
        render();
      });

      subrazaSelect.addEventListener('change', () => {
        render();
      });

      addClassBtn.addEventListener('click', () => {
        const abierto = !classPickerEl.hasAttribute('hidden');
        if (abierto) classPickerEl.setAttribute('hidden', '');
        else {
          renderClassPicker();
          classPickerEl.removeAttribute('hidden');
        }
      });

      document.addEventListener('click', () => {
        cerrarMenusCatalogo();
      });

      render();
    })();
  </script>
</body>
</html>
