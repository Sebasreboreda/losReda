<script>
  (function () {
    const trigger = document.getElementById('avatar-trigger');
    const preview = document.getElementById('avatar-selected-preview');
    const dropdown = document.getElementById('avatar-dropdown');
    const nameInput = document.getElementById('nombre-personaje');
    const imageInput = document.getElementById('personaje-imagen');
    const label = trigger ? trigger.querySelector('.avatar-picker__label') : null;
    const itemButtons = dropdown ? Array.from(dropdown.querySelectorAll('.avatar-picker__item[data-image-url]')) : [];
    const STORAGE_NAME_KEY = 'crearPersonaje.nombre';
    const STORAGE_IMAGE_KEY = 'crearPersonaje.imagen';
    if (!trigger || !dropdown) return;

    const storage = window.sessionStorage;

    function setPickerImage(imageUrl) {
      if (imageUrl) {
        trigger.classList.add('avatar-picker__trigger--selected');
        if (preview) {
          preview.src = imageUrl;
          preview.hidden = false;
        }
        if (label) label.textContent = '';
      } else {
        trigger.classList.remove('avatar-picker__trigger--selected');
        if (preview) {
          preview.src = '';
          preview.hidden = true;
        }
        if (label) label.textContent = 'Haz click para elegir imagen';
      }

      if (imageInput) imageInput.value = imageUrl || '';

      itemButtons.forEach((btn) => {
        const isSelected = btn.dataset.imageUrl === imageUrl;
        btn.classList.toggle('is-selected', isSelected);
        btn.setAttribute('aria-pressed', isSelected ? 'true' : 'false');
      });
    }

    function toggleDropdown(show) {
      const isHidden = dropdown.hasAttribute('hidden');
      const shouldShow = typeof show === 'boolean' ? show : isHidden;
      if (shouldShow) {
        dropdown.removeAttribute('hidden');
        trigger.setAttribute('aria-expanded', 'true');
      } else {
        dropdown.setAttribute('hidden', '');
        trigger.setAttribute('aria-expanded', 'false');
      }
    }

    const savedName = storage.getItem(STORAGE_NAME_KEY) || '';
    const savedImage = storage.getItem(STORAGE_IMAGE_KEY) || '';

    if (nameInput && savedName) nameInput.value = savedName;
    if (savedImage) setPickerImage(savedImage);

    trigger.addEventListener('click', () => {
      toggleDropdown();
    });

    itemButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const imageUrl = btn.dataset.imageUrl || '';
        setPickerImage(imageUrl);
        storage.setItem(STORAGE_IMAGE_KEY, imageUrl);
        toggleDropdown(false);
      });
    });

    if (nameInput) {
      nameInput.addEventListener('input', () => {
        storage.setItem(STORAGE_NAME_KEY, nameInput.value || '');
      });
    }
  })();
</script>
