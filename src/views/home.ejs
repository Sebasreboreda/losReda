<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
</head>
<body class="site">
  <%- include('partials/header') %>

  <main class="site-main">
    <div class="content-shell">
      <h1 class="page-title">Personajes prueba</h1>

      <div class="home-intro">
        <%- include('partials/homeMensajes', { mensajes, user }) %>
      </div>

      <div class="home-actions">
        <a href="/personajes/crear/1" class="btn btn-primary">Crear personaje</a>
      </div>

      <section class="character-grid" aria-label="Lista de personajes">
        <% if (!personajes || personajes.length === 0) { %>
          <div class="empty-state">No hay personajes creados todavía.</div>
        <% } else { %>
          <% personajes.forEach((personaje) => { %>
            <%- include('partials/homePersonajeCard', { personaje }) %>
          <% }) %>
        <% } %>
      </section>

      <section class="home-users" aria-label="Usuarios de prueba">
        <strong>Usuarios registrados</strong>
        <% if (usuarios && usuarios.length > 0) { %>
          <ul>
            <% usuarios.forEach((u) => { %>
              <li><%= u.nombre %> (<%= u.correo %>)</li>
            <% }) %>
          </ul>
        <% } else { %>
          <p>No hay usuarios registrados.</p>
        <% } %>
      </section>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>